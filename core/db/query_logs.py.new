        with conn.cursor() as cur:
            cur.execute(sql, tuple(params))
            rows = cur.fetchall()

        return [_audit_row_to_payload(row) for row in rows]
    finally:
        conn.close()


def fetch_token_usage_summary(limit: int = 10) -> dict[str, Any]:
    """Aggregate token usage from LLM call logs and sanitized query logs.

    `kb_llm_call_logs` is the target source for precise per-stage model cost
    accounting. Query-log aggregates remain as a compatibility fallback for
    online RAG totals until every LLM/embedding/parser call writes call logs.
    """
    return fetch_token_usage_summary_for_identity(limit=limit)


def fetch_app_usage_report_for_identity(
    *,
    limit: int = 20,
    tenant_id: str | None = None,
    include_all_tenants: bool = False,
    app_id: str | None = None,
    api_key_id: str | None = None,
    kb_id: str | None = None,
    pipeline_domain: str | None = None,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> dict[str, Any]:
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where: list[str] = []
        params: list[Any] = []
        if tenant_id and not include_all_tenants:
            where.append("l.tenant_id = %s")
            params.append(tenant_id)
        if app_id:
            where.append("k.app_id = %s")
            params.append(app_id)
        if api_key_id:
            where.append("l.api_key_id = %s")
            params.append(api_key_id)
        if kb_id:
            where.append("l.kb_id = %s")
            params.append(kb_id)
        if pipeline_domain:
            where.append("l.pipeline_domain = %s")
            params.append(pipeline_domain)
        if start_at:
            where.append("l.created_at >= %s")
            params.append(start_at)
        if end_at:
            where.append("l.created_at <= %s")
            params.append(end_at)
        where_sql = f" WHERE {' AND '.join(where)}" if where else ""
        capped_limit = max(1, min(int(limit or 20), 100))
        from_sql = """
            FROM kb_llm_call_logs l
            LEFT JOIN kb_api_keys k ON l.api_key_id = k.id
            LEFT JOIN kb_openapi_apps a ON k.app_id = a.id
        """

        with conn.cursor() as cur:
            cur.execute(
                f"""
                SELECT
                    COUNT(*) AS request_count,
                    COALESCE(SUM(l.prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(l.completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(l.total_tokens), 0) AS total_tokens,
                    COALESCE(AVG(NULLIF(l.latency_ms, 0)), 0) AS avg_latency_ms,
                    COUNT(*) FILTER (WHERE l.status <> 'success') AS error_count,
                    MAX(l.created_at) AS last_called_at
                {from_sql}
                {where_sql}
                """,
                tuple(params),
            )
            overall = _app_usage_metric_row(cur.fetchone())

            cur.execute(
                f"""
                SELECT
                    COALESCE(k.app_id, 'console') AS app_bucket,
                    COALESCE(a.name, CASE WHEN k.app_id IS NULL THEN 'Console / internal' ELSE k.app_id END) AS app_name,
                    COUNT(*) AS request_count,
                    COALESCE(SUM(l.prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(l.completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(l.total_tokens), 0) AS total_tokens,
                    COALESCE(AVG(NULLIF(l.latency_ms, 0)), 0) AS avg_latency_ms,
                    COUNT(*) FILTER (WHERE l.status <> 'success') AS error_count,
                    MAX(l.created_at) AS last_called_at
                {from_sql}
                {where_sql}
                GROUP BY app_bucket, app_name
                ORDER BY total_tokens DESC, request_count DESC, app_bucket ASC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            by_app = [_app_usage_group_row(row, "appId", "appName") for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    COALESCE(l.api_key_id, 'console') AS api_key_bucket,
                    COALESCE(k.name, CASE WHEN l.api_key_id IS NULL THEN 'Console / internal' ELSE l.api_key_id END) AS api_key_name,
                    COALESCE(k.app_id, 'console') AS app_bucket,
                    COUNT(*) AS request_count,
                    COALESCE(SUM(l.prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(l.completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(l.total_tokens), 0) AS total_tokens,
                    COALESCE(AVG(NULLIF(l.latency_ms, 0)), 0) AS avg_latency_ms,
                    COUNT(*) FILTER (WHERE l.status <> 'success') AS error_count,
                    MAX(l.created_at) AS last_called_at
                {from_sql}
                {where_sql}
                GROUP BY api_key_bucket, api_key_name, app_bucket
                ORDER BY total_tokens DESC, request_count DESC, api_key_bucket ASC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            by_api_key = [_app_usage_api_key_row(row) for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    COALESCE(l.kb_id, '') AS kb_bucket,
                    COUNT(*) AS request_count,
                    COALESCE(SUM(l.prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(l.completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(l.total_tokens), 0) AS total_tokens,
                    COALESCE(AVG(NULLIF(l.latency_ms, 0)), 0) AS avg_latency_ms,
                    COUNT(*) FILTER (WHERE l.status <> 'success') AS error_count,
                    MAX(l.created_at) AS last_called_at
                {from_sql}
                {where_sql}
                GROUP BY kb_bucket
                ORDER BY total_tokens DESC, request_count DESC, kb_bucket ASC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            by_kb = [_app_usage_group_row(row, "kbId") for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    l.pipeline_domain,
                    COUNT(*) AS request_count,
                    COALESCE(SUM(l.prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(l.completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(l.total_tokens), 0) AS total_tokens,
                    COALESCE(AVG(NULLIF(l.latency_ms, 0)), 0) AS avg_latency_ms,
                    COUNT(*) FILTER (WHERE l.status <> 'success') AS error_count,
                    MAX(l.created_at) AS last_called_at
                {from_sql}
                {where_sql}
                GROUP BY l.pipeline_domain
                ORDER BY total_tokens DESC, request_count DESC, l.pipeline_domain ASC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            by_pipeline = [_app_usage_group_row(row, "pipelineDomain") for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    l.id,
                    l.request_id,
                    l.pipeline_domain,
                    l.pipeline_stage,
                    l.feature_name,
                    l.provider,
                    l.model_name,
                    COALESCE(l.model_version, '') AS model_version,
                    l.prompt_tokens,
                    l.completion_tokens,
                    l.total_tokens,
                    l.latency_ms,
                    l.status,
                    l.error_code,
                    l.kb_id,
                    COALESCE(l.api_key_id, 'console') AS api_key_bucket,
                    COALESCE(k.app_id, 'console') AS app_bucket,
                    COALESCE(a.name, '') AS app_name,
                    l.created_at
                {from_sql}
                {where_sql}
                ORDER BY l.created_at DESC, l.id DESC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            recent_calls = [_app_usage_call_row(row) for row in cur.fetchall()]

        return {
            "source": "kb_llm_call_logs",
            "scope": "all_tenants" if include_all_tenants else ("tenant" if tenant_id else "unscoped"),
            "filters": {
                "appId": app_id or "",
                "apiKeyId": api_key_id or "",
                "kbId": kb_id or "",
                "pipelineDomain": pipeline_domain or "",
                "startAt": _iso(start_at) if start_at else "",
                "endAt": _iso(end_at) if end_at else "",
            },
            "overall": overall,
            "byApp": by_app,
            "byApiKey": by_api_key,
            "byKnowledgeBase": by_kb,
            "byPipeline": by_pipeline,
            "recentCalls": recent_calls,
        }
    finally:
        conn.close()


def fetch_processing_cost_tasks_for_identity(
    *,
    limit: int = 20,
    tenant_id: str | None = None,
    include_all_tenants: bool = False,
    visible_kb_ids: list[str] | None = None,
    task_id: str | None = None,
    kb_id: str | None = None,
    document_id: str | None = None,
    pipeline_domain: str | None = None,
    pipeline_stage: str | None = None,
    event_type: str | None = None,
    provider: str | None = None,
    model_name: str | None = None,
    api_key_id: str | None = None,
    app_id: str | None = None,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> dict[str, Any]:
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where, params = _processing_cost_filters(
            tenant_id=tenant_id,
            include_all_tenants=include_all_tenants,
            visible_kb_ids=visible_kb_ids,
            task_id=task_id,
            kb_id=kb_id,
            document_id=document_id,
            pipeline_domain=pipeline_domain,
            pipeline_stage=pipeline_stage,
            event_type=event_type,
            provider=provider,
            model_name=model_name,
            api_key_id=api_key_id,
            app_id=app_id,
            start_at=start_at,
            end_at=end_at,
        )
        where.append("(task_id IS NOT NULL OR request_id IS NOT NULL)")
        where_sql = f"WHERE {' AND '.join(where)}"
        capped_limit = max(1, min(int(limit or 20), 100))
        with conn.cursor() as cur:
            cur.execute(
                f"""
                SELECT
                    COALESCE(task_id, request_id, '') AS task_bucket,
                    MAX(request_id) AS request_id,
                    MAX(kb_id) AS kb_id,
                    MAX(tenant_id) AS tenant_id,
                    MAX(actor_id) AS actor_id,
                    MAX(actor_source) AS actor_source,
                    MAX(api_key_id) AS api_key_id,
                    MAX(app_id) AS app_id,
                    COUNT(*) AS event_count,
                    COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(total_tokens), 0) AS total_tokens,
                    COALESCE(SUM(duration_ms), 0) AS duration_ms_sum,
                    COALESCE(AVG(NULLIF(duration_ms, 0)), 0) AS avg_duration_ms,
                    COUNT(*) FILTER (WHERE status <> 'success') AS error_count,
                    COALESCE(SUM(estimated_cost), 0) AS estimated_cost,
                    COUNT(estimated_cost) AS cost_available_count,
                    MIN(occurred_at) AS first_occurred_at,
                    MAX(occurred_at) AS last_occurred_at
                FROM kb_processing_cost_events
                {where_sql}
                GROUP BY task_bucket
                ORDER BY last_occurred_at DESC, total_tokens DESC, event_count DESC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            rows = cur.fetchall()
            cur.execute(
                f"""
                SELECT
                    COUNT(*) AS event_count,
                    COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(total_tokens), 0) AS total_tokens,
                    COALESCE(SUM(duration_ms), 0) AS duration_ms_sum,
                    COUNT(*) FILTER (WHERE status <> 'success') AS error_count,
                    COALESCE(SUM(estimated_cost), 0) AS estimated_cost
                FROM kb_processing_cost_events
                {where_sql}
                """,
                tuple(params),
            )
            overall = _processing_cost_overall_row(cur.fetchone())
        return {
            "source": "kb_processing_cost_events",
            "scope": "all_tenants" if include_all_tenants else ("tenant" if tenant_id else "unscoped"),
            "overall": overall,
            "items": [_processing_task_row_to_payload(row) for row in rows],
        }
    finally:
        conn.close()


def fetch_processing_cost_documents_for_identity(
    *,
    limit: int = 20,
    tenant_id: str | None = None,
    include_all_tenants: bool = False,
    visible_kb_ids: list[str] | None = None,
    document_id: str | None = None,
    kb_id: str | None = None,
    pipeline_domain: str | None = None,
    pipeline_stage: str | None = None,
    event_type: str | None = None,
    provider: str | None = None,
    model_name: str | None = None,
    api_key_id: str | None = None,
    app_id: str | None = None,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> dict[str, Any]:
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where, params = _processing_cost_filters(
            table_alias="e",
            tenant_id=tenant_id,
            include_all_tenants=include_all_tenants,
            visible_kb_ids=visible_kb_ids,
            document_id=document_id,
            kb_id=kb_id,
            pipeline_domain=pipeline_domain,
            pipeline_stage=pipeline_stage,
            event_type=event_type,
            provider=provider,
            model_name=model_name,
            api_key_id=api_key_id,
            app_id=app_id,
            start_at=start_at,
            end_at=end_at,
        )
        where.append("e.document_id IS NOT NULL")
        where_sql = f"WHERE {' AND '.join(where)}"
        capped_limit = max(1, min(int(limit or 20), 100))
        with conn.cursor() as cur:
            cur.execute(
                f"""
                SELECT
                    e.document_id::text AS document_id,
                    MAX(e.kb_id) AS kb_id,
                    MAX(COALESCE(d.filename, '')) AS filename,
                    COUNT(*) AS event_count,
                    COUNT(DISTINCT COALESCE(e.task_id, e.request_id)) AS task_count,
                    COALESCE(SUM(e.prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(e.completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(e.total_tokens), 0) AS total_tokens,
                    COALESCE(SUM(e.duration_ms), 0) AS duration_ms_sum,
                    COALESCE(AVG(NULLIF(e.duration_ms, 0)), 0) AS avg_duration_ms,
                    COUNT(*) FILTER (WHERE e.status <> 'success') AS error_count,
                    COALESCE(SUM(e.estimated_cost), 0) AS estimated_cost,
                    COUNT(e.estimated_cost) AS cost_available_count,
                    MAX(e.occurred_at) AS last_occurred_at
                FROM kb_processing_cost_events e
                LEFT JOIN documents d ON e.document_id = d.id
                {where_sql}
                GROUP BY e.document_id
                ORDER BY last_occurred_at DESC, total_tokens DESC, event_count DESC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            rows = cur.fetchall()
            cur.execute(
                f"""
                SELECT
                    COUNT(*) AS event_count,
                    COALESCE(SUM(e.prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(e.completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(e.total_tokens), 0) AS total_tokens,
                    COALESCE(SUM(e.duration_ms), 0) AS duration_ms_sum,
                    COUNT(*) FILTER (WHERE e.status <> 'success') AS error_count,
                    COALESCE(SUM(e.estimated_cost), 0) AS estimated_cost
                FROM kb_processing_cost_events e
                LEFT JOIN documents d ON e.document_id = d.id
                {where_sql}
                """,
                tuple(params),
            )
            overall = _processing_cost_overall_row(cur.fetchone())
        return {
            "source": "kb_processing_cost_events",
            "scope": "all_tenants" if include_all_tenants else ("tenant" if tenant_id else "unscoped"),
            "overall": overall,
            "items": [_processing_document_row_to_payload(row) for row in rows],
        }
    finally:
        conn.close()


