@dataclass(frozen=True)
class RagQueryLogRecord:
    request_id: str
    pipeline_domain: str
    kb_id: str
    query: str
    answer: str = ""
    identity: IdentityContext | None = None
    cannot_answer: bool = False
    relevance_score: float | None = None
    faithfulness_score: float | None = None
    prompt_tokens: int = 0
    completion_tokens: int = 0
    total_tokens: int = 0
    latency_ms: int = 0
    status: str = "success"
    error_code: str | None = None
    api_key_id: str | None = None


@dataclass(frozen=True)
class LlmCallLogRecord:
    pipeline_domain: str
    pipeline_stage: str
    feature_name: str
    provider: str
    model_name: str
    kb_id: str | None = None
    request_id: str | None = None
    identity: IdentityContext | None = None
    api_key_id: str | None = None
    app_id: str | None = None
    document_id: str | None = None
    usage_target_type: str = ""
    event_type: str = ""
    usage_source: str = "runtime"
    model_version: str = ""
    prompt_tokens: int = 0
    completion_tokens: int = 0
    total_tokens: int = 0
    latency_ms: int = 0
    status: str = "success"
    error_code: str | None = None


@dataclass(frozen=True)
class ProcessingCostEventRecord:
    event_type: str
    pipeline_domain: str
    pipeline_stage: str
    feature_name: str = ""
    task_id: str | None = None
    request_id: str | None = None
    usage_target_type: str = ""
    document_id: str | None = None
    kb_id: str | None = None
    identity: IdentityContext | None = None
    api_key_id: str | None = None
    app_id: str | None = None
    provider: str | None = None
    model_name: str | None = None
    external_job_id: str | None = None
    metric_value: int | float | Decimal | None = None
    metric_unit: str | None = None
    prompt_tokens: int = 0
    completion_tokens: int = 0
    total_tokens: int = 0
    duration_ms: int = 0
    status: str = "success"
    error_code: str | None = None
    estimated_cost: int | float | Decimal | None = None
    cost_currency: str | None = None
    cost_source: str = "not_available"
    llm_call_log_id: int | None = None
    usage_source: str = "runtime"
    collection_status: str = "recorded"
    metadata: dict[str, Any] | None = None
    occurred_at: datetime | None = None


@dataclass(frozen=True)
class TokenPricing:
    source: str
    currency: str
    prompt_per_1k: Decimal = Decimal("0")
    completion_per_1k: Decimal = Decimal("0")
    total_per_1k: Decimal = Decimal("0")
    provider: str = ""
    model_name: str = ""
    event_type: str = ""
    matched_rule: str = ""

    @property
    def configured(self) -> bool:
        return any(rate > 0 for rate in (self.prompt_per_1k, self.completion_per_1k, self.total_per_1k))


@dataclass(frozen=True)
class ProcessingCostEstimate:
    estimated_cost: Decimal | None
    currency: str | None
    source: str
    pricing: dict[str, Any] | None = None


@dataclass(frozen=True)
class AuditLogRecord:
    action: str
    resource_type: str
    resource_id: str | None = None
    identity: IdentityContext | None = None
    request_id: str | None = None
    kb_id: str | None = None
    api_key_id: str | None = None
    outcome: str = "success"
    risk_level: str = "low"
    summary: str = ""
    metadata: dict[str, Any] | None = None


def append_rag_query_log(record: RagQueryLogRecord) -> bool:
    """Append a sanitized query log. Logging failure must not break user queries."""
    try:
        conn = get_db_connection()
    except Exception:
        return False

    identity = record.identity
    api_key_id = record.api_key_id or _api_key_id_from_identity(identity)
    try:
        ensure_db_schema(conn)
        with conn.cursor() as cur:
            cur.execute(
                """
                INSERT INTO kb_rag_query_logs(
                    request_id, pipeline_domain, pipeline_stage, tenant_id, actor_id,
                    kb_id, api_key_id, query_hash, query_summary, answer_summary,
                    cannot_answer, relevance_score, faithfulness_score,
                    prompt_tokens, completion_tokens, total_tokens,
                    latency_ms, status, error_code
                )
                VALUES(
                    %s, %s, 'query', %s, %s,
                    %s, %s, %s, %s, %s,
                    %s, %s, %s,
                    %s, %s, %s,
                    %s, %s, %s
                )
                ON CONFLICT(request_id) DO NOTHING
                """,
                (
                    record.request_id,
                    record.pipeline_domain,
                    identity.tenant_id if identity and identity.enforce_access else None,
                    identity.user_id if identity and identity.enforce_access else None,
                    record.kb_id,
                    api_key_id,
                    _sha256(record.query),
                    _summary(record.query),
                    _summary(record.answer),
                    record.cannot_answer,
                    record.relevance_score,
                    record.faithfulness_score,
                    max(0, int(record.prompt_tokens or 0)),
                    max(0, int(record.completion_tokens or 0)),
                    max(0, int(record.total_tokens or 0)),
                    max(0, int(record.latency_ms or 0)),
                    record.status,
                    record.error_code,
                ),
            )
        conn.commit()
        return True
    except Exception:
        if hasattr(conn, "rollback"):
            conn.rollback()
        return False
    finally:
        conn.close()


def append_llm_call_log(record: LlmCallLogRecord) -> bool:
    """Append a model-call usage log. Logging failure must not break pipelines."""
    try:
        conn = get_db_connection()
    except Exception:
        return False

    identity = record.identity
    api_key_id = record.api_key_id or _api_key_id_from_identity(identity)
    app_id = record.app_id
    prompt_tokens = max(0, int(record.prompt_tokens or 0))
    completion_tokens = max(0, int(record.completion_tokens or 0))
    total_tokens = max(0, int(record.total_tokens or 0))
    if total_tokens <= 0:
        total_tokens = prompt_tokens + completion_tokens
    latency_ms = max(0, int(record.latency_ms or 0))
    event_type = _llm_event_type(record)
    usage_target_type = _usage_target_type(record)
    pricing = _resolve_token_pricing(record, event_type=event_type)
    estimated_cost = _estimate_token_cost(
        pricing=pricing,
        prompt_tokens=prompt_tokens,
        completion_tokens=completion_tokens,
        total_tokens=total_tokens,
    )
    try:
        ensure_db_schema(conn)
        with conn.cursor() as cur:
            cur.execute(
                """
                INSERT INTO kb_llm_call_logs(
                    request_id, tenant_id, actor_id, actor_source, kb_id, api_key_id, app_id,
                    document_id, usage_target_type, event_type, usage_source,
                    pipeline_domain, pipeline_stage, feature_name,
                    provider, model_name, model_version,
                    prompt_tokens, completion_tokens, total_tokens,
                    latency_ms, status, error_code
                )
                VALUES(
                    %s, %s, %s, %s, %s, %s, %s,
                    NULLIF(%s, '')::uuid, %s, %s, %s,
                    %s, %s, %s,
                    %s, %s, %s,
                    %s, %s, %s,
                    %s, %s, %s
                )
                RETURNING id
                """,
                (
                    record.request_id,
                    identity.tenant_id if identity and identity.enforce_access else None,
                    identity.user_id if identity and identity.enforce_access else None,
                    identity.source if identity else None,
                    record.kb_id,
                    api_key_id,
                    app_id,
                    record.document_id or "",
                    usage_target_type,
                    event_type,
                    _safe_slug(record.usage_source, "runtime", 50),
                    record.pipeline_domain,
                    record.pipeline_stage,
                    record.feature_name,
                    record.provider,
                    record.model_name,
                    record.model_version,
                    prompt_tokens,
                    completion_tokens,
                    total_tokens,
                    latency_ms,
                    record.status,
                    record.error_code,
                ),
            )
            row = cur.fetchone() if hasattr(cur, "fetchone") else None
            llm_call_log_id = int(row[0]) if row else None
            _upsert_token_usage_hourly(cur, record, identity=identity, api_key_id=api_key_id, pricing=pricing)
            _insert_processing_cost_event(
                cur,
                ProcessingCostEventRecord(
                    event_type=event_type,
                    pipeline_domain=record.pipeline_domain,
                    pipeline_stage=record.pipeline_stage,
                    feature_name=record.feature_name,
                    task_id=record.request_id if usage_target_type == "ingestion_task" else None,
                    request_id=record.request_id,
                    usage_target_type=usage_target_type,
                    document_id=record.document_id,
                    kb_id=record.kb_id,
                    identity=identity,
                    api_key_id=api_key_id,
                    app_id=app_id,
                    provider=record.provider,
                    model_name=record.model_name,
                    prompt_tokens=prompt_tokens,
                    completion_tokens=completion_tokens,
                    total_tokens=total_tokens,
                    duration_ms=latency_ms,
                    status=record.status,
                    error_code=record.error_code,
                    estimated_cost=estimated_cost,
                    cost_currency=pricing.currency,
                    cost_source=pricing.source,
                    llm_call_log_id=llm_call_log_id,
                    usage_source=record.usage_source,
                    collection_status="recorded",
                    metadata={
                        "modelVersion": record.model_version or "",
                        "pricing": _token_pricing_metadata(pricing),
                    },
                ),
            )
        conn.commit()
        return True
    except Exception:
        if hasattr(conn, "rollback"):
            conn.rollback()
        return False
    finally:
        conn.close()


def _upsert_token_usage_hourly(
    cur: Any,
    record: LlmCallLogRecord,
    *,
    identity: IdentityContext | None,
    api_key_id: str | None,
    pricing: TokenPricing | None = None,
) -> None:
    prompt_tokens = max(0, int(record.prompt_tokens or 0))
    completion_tokens = max(0, int(record.completion_tokens or 0))
    total_tokens = max(0, int(record.total_tokens or 0))
    if total_tokens <= 0:
        total_tokens = prompt_tokens + completion_tokens
    resolved_pricing = pricing or _resolve_token_pricing(record)
    estimated_cost = _estimate_token_cost(
        pricing=resolved_pricing,
        prompt_tokens=prompt_tokens,
        completion_tokens=completion_tokens,
        total_tokens=total_tokens,
    )
    hourly_estimated_cost = estimated_cost or Decimal("0")
    cur.execute(
        """
        INSERT INTO kb_token_usage_hourly(
            hour_bucket, tenant_id, kb_id, api_key_id, pipeline_domain, pipeline_stage, feature_name,
            request_count, prompt_tokens, completion_tokens, total_tokens,
            latency_ms_sum, error_count, estimated_cost, updated_at
        )
        VALUES(
            date_trunc('hour', NOW()), %s, %s, %s, %s, %s, %s,
            1, %s, %s, %s,
            %s, %s, %s, NOW()
        )
        ON CONFLICT(hour_bucket, tenant_id, kb_id, api_key_id, pipeline_domain, pipeline_stage, feature_name)
        DO UPDATE SET
            request_count = kb_token_usage_hourly.request_count + EXCLUDED.request_count,
            prompt_tokens = kb_token_usage_hourly.prompt_tokens + EXCLUDED.prompt_tokens,
            completion_tokens = kb_token_usage_hourly.completion_tokens + EXCLUDED.completion_tokens,
            total_tokens = kb_token_usage_hourly.total_tokens + EXCLUDED.total_tokens,
            latency_ms_sum = kb_token_usage_hourly.latency_ms_sum + EXCLUDED.latency_ms_sum,
            error_count = kb_token_usage_hourly.error_count + EXCLUDED.error_count,
            estimated_cost = kb_token_usage_hourly.estimated_cost + EXCLUDED.estimated_cost,
            updated_at = NOW()
        """,
        (
            identity.tenant_id if identity and identity.enforce_access else "",
            record.kb_id or "",
            api_key_id or "",
            record.pipeline_domain,
            record.pipeline_stage,
            record.feature_name,
            prompt_tokens,
            completion_tokens,
            total_tokens,
            max(0, int(record.latency_ms or 0)),
            0 if record.status == "success" else 1,
            hourly_estimated_cost,
        ),
    )


def append_processing_cost_event(record: ProcessingCostEventRecord) -> bool:
    """Append a non-model processing cost event. Logging failure must not break pipelines."""
    try:
        conn = get_db_connection()
    except Exception:
        return False

    try:
        ensure_db_schema(conn)
        with conn.cursor() as cur:
            _insert_processing_cost_event(cur, record)
        conn.commit()
        return True
    except Exception:
        if hasattr(conn, "rollback"):
            conn.rollback()
        return False
    finally:
        conn.close()


def _insert_processing_cost_event(cur: Any, record: ProcessingCostEventRecord) -> None:
    identity = record.identity
    api_key_id = record.api_key_id or _api_key_id_from_identity(identity)
    task_id = record.task_id or (_request_as_task_id(record.request_id, record.usage_target_type))
    usage_target_type = _safe_slug(record.usage_target_type, "ingestion_task" if task_id else "request", 50)
    metadata_dict = dict(record.metadata or {})
    estimated_cost = _decimal_or_none(record.estimated_cost)
    cost_currency = record.cost_currency
    cost_source = record.cost_source
    if estimated_cost is None and record.llm_call_log_id is None:
        estimate = _estimate_processing_cost(record)
        estimated_cost = estimate.estimated_cost
        if estimate.currency:
            cost_currency = estimate.currency
        cost_source = estimate.source
        if estimate.pricing:
            metadata_dict["pricing"] = estimate.pricing
            metadata_dict["costEstimatedAt"] = datetime.now(timezone.utc).isoformat()
    metadata = _safe_metadata_json(metadata_dict)
    cur.execute(
        """
        INSERT INTO kb_processing_cost_events(
            event_type, pipeline_domain, pipeline_stage, feature_name,
            task_id, request_id, usage_target_type, document_id,
            kb_id, tenant_id, actor_id, actor_source, api_key_id, app_id,
            provider, model_name, external_job_id,
            metric_value, metric_unit,
            prompt_tokens, completion_tokens, total_tokens, duration_ms,
            status, error_code, estimated_cost, cost_currency, cost_source,
            llm_call_log_id, usage_source, collection_status, metadata, occurred_at
        )
        VALUES(
            %s, %s, %s, %s,
            %s, %s, %s, NULLIF(%s, '')::uuid,
            %s, %s, %s, %s, %s, %s,
            %s, %s, %s,
            %s, %s,
            %s, %s, %s, %s,
            %s, %s, %s, %s, %s,
            %s, %s, %s, %s::jsonb, COALESCE(%s, NOW())
        )
        ON CONFLICT (llm_call_log_id) WHERE llm_call_log_id IS NOT NULL DO NOTHING
        """,
        (
            _safe_slug(record.event_type, "processing", 50),
            _safe_slug(record.pipeline_domain, "unknown", 50),
            _safe_slug(record.pipeline_stage, "unknown", 50),
            _summary(record.feature_name or "", 100),
            task_id,
            record.request_id,
            usage_target_type,
            record.document_id or "",
            record.kb_id,
            identity.tenant_id if identity and identity.enforce_access else None,
            identity.user_id if identity and identity.enforce_access else None,
            identity.source if identity else None,
            api_key_id,
            record.app_id,
            _summary(record.provider or "", 100) or None,
            _summary(record.model_name or "", 200) or None,
            _summary(record.external_job_id or "", 255) or None,
            _decimal_or_none(record.metric_value),
            _safe_slug(record.metric_unit or "", "", 50) or None,
            max(0, int(record.prompt_tokens or 0)),
            max(0, int(record.completion_tokens or 0)),
            max(0, int(record.total_tokens or 0)),
            max(0, int(record.duration_ms or 0)),
            _safe_slug(record.status, "success", 50),
            _summary(record.error_code or "", 100) or None,
            estimated_cost,
            _summary(cost_currency or "", 20) or None,
            _safe_slug(cost_source, "not_available", 50),
            record.llm_call_log_id,
            _safe_slug(record.usage_source, "runtime", 50),
            _safe_slug(record.collection_status, "recorded", 50),
            metadata,
            record.occurred_at,
        ),
    )


def refresh_token_usage_hourly(
    *,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> dict[str, Any]:
    """Rebuild hourly token rollups from call logs for a time window."""
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where: list[str] = []
        params: list[Any] = []
        if start_at:
            where.append("created_at >= %s")
            params.append(start_at)
        if end_at:
            where.append("created_at <= %s")
            params.append(end_at)
        where_sql = f"WHERE {' AND '.join(where)}" if where else ""
        delete_where = where_sql.replace("created_at", "hour_bucket")
        insert_where_sql = where_sql.replace("created_at", "l.created_at")

        with conn.cursor() as cur:
            if delete_where:
                cur.execute(f"DELETE FROM kb_token_usage_hourly {delete_where}", tuple(params))
            else:
                cur.execute("DELETE FROM kb_token_usage_hourly")
            deleted = int(getattr(cur, "rowcount", 0) or 0)
            prompt_rate, completion_rate, total_rate = _token_cost_rates()
            cur.execute(
                f"""
                INSERT INTO kb_token_usage_hourly(
                    hour_bucket, tenant_id, kb_id, api_key_id, pipeline_domain, pipeline_stage, feature_name,
                    request_count, prompt_tokens, completion_tokens, total_tokens,
                    latency_ms_sum, error_count, estimated_cost, updated_at
                )
                SELECT
                    date_trunc('hour', l.created_at) AS hour_bucket,
                    COALESCE(l.tenant_id, '') AS tenant_id,
                    COALESCE(l.kb_id, '') AS kb_id,
                    COALESCE(l.api_key_id, '') AS api_key_id,
                    l.pipeline_domain,
                    l.pipeline_stage,
                    l.feature_name,
                    COUNT(*)::int AS request_count,
                    COALESCE(SUM(l.prompt_tokens), 0)::bigint AS prompt_tokens,
                    COALESCE(SUM(l.completion_tokens), 0)::bigint AS completion_tokens,
                    COALESCE(SUM(l.total_tokens), 0)::bigint AS total_tokens,
                    COALESCE(SUM(l.latency_ms), 0)::bigint AS latency_ms_sum,
                    COUNT(*) FILTER (WHERE l.status <> 'success')::int AS error_count,
                    COALESCE(SUM(
                        COALESCE(
                            e.estimated_cost,
                            l.prompt_tokens / 1000.0 * %s::numeric
                            + l.completion_tokens / 1000.0 * %s::numeric
                            + l.total_tokens / 1000.0 * %s::numeric
                        )
                    ), 0)::numeric(18, 6) AS estimated_cost,
                    NOW() AS updated_at
                FROM kb_llm_call_logs l
                LEFT JOIN kb_processing_cost_events e ON e.llm_call_log_id = l.id
                {insert_where_sql}
                GROUP BY 1, 2, 3, 4, 5, 6, 7
                """,
                (prompt_rate, completion_rate, total_rate, *params),
            )
            inserted = int(getattr(cur, "rowcount", 0) or 0)
        conn.commit()
        return {"refreshed": True, "deleted": deleted, "inserted": inserted}
    except Exception:
        if hasattr(conn, "rollback"):
            conn.rollback()
        raise
    finally:
        conn.close()


def refresh_processing_cost_estimates(
    *,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> dict[str, Any]:
    """Recalculate trusted model costs and project cost estimates."""
    prompt_rate, completion_rate, total_rate = _token_cost_rates()
    model_rates_available = _has_configured_model_rates() or any(rate > 0 for rate in (prompt_rate, completion_rate, total_rate))
    project_rates_available = _has_processing_cost_rates()
    if not model_rates_available and not project_rates_available:
        return {
            "refreshed": False,
            "updated": 0,
            "modelUpdated": 0,
            "projectUpdated": 0,
            "backfilled": 0,
            "skipped": 0,
            "hourly": {"refreshed": False, "deleted": 0, "inserted": 0},
        }

    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where: list[str] = [
            "e.llm_call_log_id IS NOT NULL",
            "(e.estimated_cost IS NULL OR e.cost_source IN ('not_available', 'missing_model_rate'))",
        ]
        params: list[Any] = []
        if start_at:
            where.append("e.occurred_at >= %s")
            params.append(start_at)
        if end_at:
            where.append("e.occurred_at <= %s")
            params.append(end_at)
        where_sql = f"WHERE {' AND '.join(where)}"

        model_updated = 0
        project_updated = 0
        backfilled = 0
        skipped = 0
        with conn.cursor() as cur:
            if model_rates_available:
                cur.execute(
                    f"""
                    SELECT
                        e.event_id,
                        e.event_type,
                        e.occurred_at,
                        e.metadata,
                        l.pipeline_domain,
                        l.pipeline_stage,
                        l.feature_name,
                        l.provider,
                        l.model_name,
                        l.model_version,
                        l.kb_id,
                        l.request_id,
                        l.document_id::text,
                        l.usage_target_type,
                        l.usage_source,
                        l.prompt_tokens,
                        l.completion_tokens,
                        l.total_tokens,
                        l.latency_ms,
                        l.status,
                        l.error_code,
                        l.api_key_id,
                        l.app_id
                    FROM kb_processing_cost_events e
                    JOIN kb_llm_call_logs l ON l.id = e.llm_call_log_id
                    {where_sql}
                    ORDER BY e.occurred_at ASC, e.created_at ASC
                    """,
                    tuple(params),
                )
                rows = cur.fetchall()
                for row in rows:
                    record = LlmCallLogRecord(
                        pipeline_domain=row[4] or "",
                        pipeline_stage=row[5] or "",
                        feature_name=row[6] or "",
                        provider=row[7] or "",
                        model_name=row[8] or "",
                        model_version=row[9] or "",
                        kb_id=row[10] or None,
                        request_id=row[11] or None,
                        document_id=row[12] or None,
                        usage_target_type=row[13] or "",
                        event_type=row[1] or "",
                        usage_source=row[14] or "runtime",
                        prompt_tokens=int(row[15] or 0),
                        completion_tokens=int(row[16] or 0),
                        total_tokens=int(row[17] or 0),
                        latency_ms=int(row[18] or 0),
                        status=row[19] or "success",
                        error_code=row[20] or None,
                        api_key_id=row[21] or None,
                        app_id=row[22] or None,
                    )
                    pricing = _resolve_token_pricing(record, event_type=row[1] or None)
                    estimated_cost = _estimate_token_cost(
                        pricing=pricing,
                        prompt_tokens=record.prompt_tokens,
                        completion_tokens=record.completion_tokens,
                        total_tokens=record.total_tokens,
                    )
                    if estimated_cost is None:
                        skipped += 1
                        continue
                    metadata = row[3] or {}
                    if isinstance(metadata, str):
                        try:
                            metadata = json.loads(metadata)
                        except json.JSONDecodeError:
                            metadata = {}
                    if not isinstance(metadata, dict):
                        metadata = {}
                    metadata = {
                        **metadata,
                        "pricing": _token_pricing_metadata(pricing),
                        "pricingRefreshedAt": datetime.now(timezone.utc).isoformat(),
                    }
                    cur.execute(
                        """
                        UPDATE kb_processing_cost_events
                        SET estimated_cost = %s,
                            cost_currency = %s,
                            cost_source = %s,
                            metadata = %s::jsonb
                        WHERE event_id = %s
                        """,
                        (
                            estimated_cost,
                            pricing.currency,
                            pricing.source,
                            _safe_metadata_json(metadata),
                            row[0],
                        ),
                    )
                    model_updated += int(getattr(cur, "rowcount", 0) or 0)
                backfilled, backfill_skipped = _backfill_missing_processing_cost_events_from_llm_logs(
                    cur,
                    start_at=start_at,
                    end_at=end_at,
                )
                skipped += backfill_skipped
            if project_rates_available:
                project_updated, project_skipped = _refresh_project_processing_cost_events(
                    cur,
                    start_at=start_at,
                    end_at=end_at,
                )
                skipped += project_skipped
        conn.commit()
    except Exception:
        if hasattr(conn, "rollback"):
            conn.rollback()
        raise
    finally:
        conn.close()

    hourly = {"refreshed": False, "deleted": 0, "inserted": 0}
    if model_updated > 0 or backfilled > 0:
        hourly = refresh_token_usage_hourly()
    updated = model_updated + project_updated
    return {
        "refreshed": True,
        "updated": updated,
        "modelUpdated": model_updated,
        "projectUpdated": project_updated,
        "backfilled": backfilled,
        "skipped": skipped,
        "hourly": hourly,
    }


def _backfill_missing_processing_cost_events_from_llm_logs(
    cur: Any,
    *,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> tuple[int, int]:
    """Create processing-cost rows for historical model calls that predate the ledger."""
    where: list[str] = ["e.llm_call_log_id IS NULL"]
    params: list[Any] = []
    if start_at:
        where.append("l.created_at >= %s")
        params.append(start_at)
    if end_at:
        where.append("l.created_at <= %s")
        params.append(end_at)
    where_sql = f"WHERE {' AND '.join(where)}"
    cur.execute(
        f"""
        SELECT
            l.id,
            l.request_id,
            l.tenant_id,
            l.actor_id,
            l.actor_source,
            l.kb_id,
            l.api_key_id,
            l.app_id,
            l.document_id::text,
            l.usage_target_type,
            l.event_type,
            l.usage_source,
            l.pipeline_domain,
            l.pipeline_stage,
            l.feature_name,
            l.provider,
            l.model_name,
            l.model_version,
            l.prompt_tokens,
            l.completion_tokens,
            l.total_tokens,
            l.latency_ms,
            l.status,
            l.error_code,
            l.created_at
        FROM kb_llm_call_logs l
        LEFT JOIN kb_processing_cost_events e ON e.llm_call_log_id = l.id
        {where_sql}
        ORDER BY l.created_at ASC, l.id ASC
        """,
        tuple(params),
    )
    rows = cur.fetchall()
    backfilled = 0
    skipped = 0
    for row in rows:
        record = LlmCallLogRecord(
            request_id=row[1] or None,
            identity=None,
            kb_id=row[5] or None,
            api_key_id=row[6] or None,
            app_id=row[7] or None,
            document_id=row[8] or None,
            usage_target_type=row[9] or "",
            event_type=row[10] or "",
            usage_source=row[11] or "runtime",
            pipeline_domain=row[12] or "",
            pipeline_stage=row[13] or "",
            feature_name=row[14] or "",
            provider=row[15] or "",
            model_name=row[16] or "",
            model_version=row[17] or "",
            prompt_tokens=int(row[18] or 0),
            completion_tokens=int(row[19] or 0),
            total_tokens=int(row[20] or 0),
            latency_ms=int(row[21] or 0),
            status=row[22] or "success",
            error_code=row[23] or None,
        )
        event_type = _llm_event_type(record)
        usage_target_type = _usage_target_type(record)
        pricing = _resolve_token_pricing(record, event_type=event_type)
        estimated_cost = _estimate_token_cost(
            pricing=pricing,
            prompt_tokens=record.prompt_tokens,
            completion_tokens=record.completion_tokens,
            total_tokens=record.total_tokens,
        )
        if estimated_cost is None:
            skipped += 1
        metadata = _safe_metadata_json(
            {
                "modelVersion": record.model_version or "",
                "pricing": _token_pricing_metadata(pricing),
                "pricingBackfilledAt": datetime.now(timezone.utc).isoformat(),
            }
        )
        cur.execute(
            """
            INSERT INTO kb_processing_cost_events(
                event_type, pipeline_domain, pipeline_stage, feature_name,
                task_id, request_id, usage_target_type, document_id,
                kb_id, tenant_id, actor_id, actor_source, api_key_id, app_id,
                provider, model_name, external_job_id,
                metric_value, metric_unit,
                prompt_tokens, completion_tokens, total_tokens, duration_ms,
                status, error_code, estimated_cost, cost_currency, cost_source,
                llm_call_log_id, usage_source, collection_status, metadata, occurred_at
            )
            VALUES(
                %s, %s, %s, %s,
                %s, %s, %s, NULLIF(%s, '')::uuid,
                %s, %s, %s, %s, %s, %s,
                %s, %s, NULL,
                NULL, NULL,
                %s, %s, %s, %s,
                %s, %s, %s, %s, %s,
                %s, %s, 'backfilled', %s::jsonb, COALESCE(%s, NOW())
            )
            ON CONFLICT (llm_call_log_id) WHERE llm_call_log_id IS NOT NULL DO NOTHING
            """,
            (
                _safe_slug(event_type, "llm_enhancement", 50),
                _safe_slug(record.pipeline_domain, "unknown", 50),
                _safe_slug(record.pipeline_stage, "unknown", 50),
                _summary(record.feature_name or "", 100),
                _request_as_task_id(record.request_id, usage_target_type),
                record.request_id,
                _safe_slug(usage_target_type, "request", 50),
                record.document_id or "",
                record.kb_id,
                row[2] or None,
                row[3] or None,
                row[4] or None,
                record.api_key_id,
                record.app_id,
                _summary(record.provider or "", 100) or None,
                _summary(record.model_name or "", 200) or None,
                max(0, int(record.prompt_tokens or 0)),
                max(0, int(record.completion_tokens or 0)),
                max(0, int(record.total_tokens or 0)),
                max(0, int(record.latency_ms or 0)),
                _safe_slug(record.status, "success", 50),
                _summary(record.error_code or "", 100) or None,
                estimated_cost,
                pricing.currency,
                pricing.source,
                int(row[0]),
                _safe_slug(record.usage_source, "runtime", 50),
                metadata,
                row[24],
            ),
        )
        backfilled += int(getattr(cur, "rowcount", 0) or 0)
    return backfilled, skipped


def _refresh_project_processing_cost_events(
    cur: Any,
    *,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> tuple[int, int]:
    """Recalculate parse/OSS project estimates with current processing rates."""
    where: list[str] = [
        _project_cost_event_predicate("e"),
        "(e.estimated_cost IS NULL OR e.cost_source IN ('not_available', 'missing_processing_rate'))",
    ]
    params: list[Any] = []
    if start_at:
        where.append("e.occurred_at >= %s")
        params.append(start_at)
    if end_at:
        where.append("e.occurred_at <= %s")
        params.append(end_at)
    where_sql = f"WHERE {' AND '.join(where)}"
    cur.execute(
        f"""
        SELECT
            e.event_id,
            e.event_type,
            e.pipeline_domain,
            e.pipeline_stage,
            e.feature_name,
            e.task_id,
            e.request_id,
            e.usage_target_type,
            e.document_id::text,
            e.kb_id,
            e.provider,
            e.model_name,
            e.external_job_id,
            e.metric_value,
            e.metric_unit,
            e.duration_ms,
            e.status,
            e.error_code,
            e.cost_currency,
            e.cost_source,
            e.usage_source,
            e.collection_status,
            e.metadata,
            e.occurred_at
        FROM kb_processing_cost_events e
        {where_sql}
        ORDER BY e.occurred_at ASC, e.created_at ASC
        """,
        tuple(params),
    )
    rows = cur.fetchall()
    updated = 0
    skipped = 0
    for row in rows:
        metadata = row[22] or {}
        if isinstance(metadata, str):
            try:
                metadata = json.loads(metadata)
            except json.JSONDecodeError:
                metadata = {}
        if not isinstance(metadata, dict):
            metadata = {}
        record = ProcessingCostEventRecord(
            event_type=row[1] or "",
            pipeline_domain=row[2] or "",
            pipeline_stage=row[3] or "",
            feature_name=row[4] or "",
            task_id=row[5] or None,
            request_id=row[6] or None,
            usage_target_type=row[7] or "",
            document_id=row[8] or None,
            kb_id=row[9] or None,
            provider=row[10] or None,
            model_name=row[11] or None,
            external_job_id=row[12] or None,
            metric_value=row[13],
            metric_unit=row[14] or None,
            duration_ms=int(row[15] or 0),
            status=row[16] or "success",
            error_code=row[17] or None,
            cost_currency=row[18] or None,
            cost_source=row[19] or "not_available",
            usage_source=row[20] or "runtime",
            collection_status=row[21] or "recorded",
            metadata=metadata,
            occurred_at=row[23],
        )
        estimate = _estimate_processing_cost(record)
        if estimate.estimated_cost is None:
            skipped += 1
            continue
        refreshed_metadata = {
            **metadata,
            "pricing": estimate.pricing or metadata.get("pricing") or {},
            "pricingRefreshedAt": datetime.now(timezone.utc).isoformat(),
        }
        cur.execute(
            """
            UPDATE kb_processing_cost_events
            SET estimated_cost = %s,
                cost_currency = %s,
                cost_source = %s,
                metadata = %s::jsonb
            WHERE event_id = %s
            """,
            (
                estimate.estimated_cost,
                estimate.currency or _token_cost_currency(),
                estimate.source,
                _safe_metadata_json(refreshed_metadata),
                row[0],
            ),
        )
        updated += int(getattr(cur, "rowcount", 0) or 0)
    return updated, skipped


def has_llm_call_log(request_id: str, pipeline_stage: str | None = None) -> bool:
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where = ["request_id = %s"]
        params: list[Any] = [request_id]
        if pipeline_stage:
            where.append("pipeline_stage = %s")
            params.append(pipeline_stage)
        with conn.cursor() as cur:
            cur.execute(
                f"SELECT 1 FROM kb_llm_call_logs WHERE {' AND '.join(where)} LIMIT 1",
                tuple(params),
            )
            return cur.fetchone() is not None
    finally:
        conn.close()


def repair_llm_call_log_identity(
    request_id: str,
    *,
    identity: IdentityContext | None = None,
    kb_id: str | None = None,
    pipeline_stage: str | None = None,
) -> dict[str, Any]:
    """Fill missing tenant/actor scope on existing model-call logs.

    Historical ingestion usage rows may already contain token totals. Updating
    their scope is safer than inserting another row because this table does not
    enforce one row per request/stage.
    """
    if not request_id:
        return {"requestId": request_id, "repaired": False, "updated": 0, "reason": "missing_request_id"}
    if not identity or not identity.enforce_access:
        return {"requestId": request_id, "repaired": False, "updated": 0, "reason": "missing_identity"}

    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where = [
            "request_id = %s",
            "(tenant_id IS NULL OR tenant_id = '' OR actor_id IS NULL OR actor_id = '' OR kb_id IS NULL OR kb_id = '')",
        ]
        params: list[Any] = [
            identity.tenant_id,
            identity.user_id,
            kb_id or None,
            request_id,
        ]
        if pipeline_stage:
            where.append("pipeline_stage = %s")
            params.append(pipeline_stage)

        with conn.cursor() as cur:
            cur.execute(
                f"""
                UPDATE kb_llm_call_logs
                SET tenant_id = COALESCE(NULLIF(tenant_id, ''), %s),
                    actor_id = COALESCE(NULLIF(actor_id, ''), %s),
                    kb_id = COALESCE(NULLIF(kb_id, ''), %s)
                WHERE {' AND '.join(where)}
                """,
                tuple(params),
            )
            updated = int(getattr(cur, "rowcount", 0) or 0)
        conn.commit()
        return {
            "requestId": request_id,
            "pipelineStage": pipeline_stage or "",
            "repaired": updated > 0,
            "updated": updated,
            "reason": "updated" if updated > 0 else "nothing_to_update",
        }
    except Exception:
        if hasattr(conn, "rollback"):
            conn.rollback()
        raise
    finally:
        conn.close()


def repair_usage_document_id(
    request_id: str,
    *,
    document_id: str | None,
    kb_id: str | None = None,
) -> dict[str, Any]:
    if not request_id:
        return {"requestId": request_id, "repaired": False, "updated": 0, "reason": "missing_request_id"}
    if not document_id:
        return {"requestId": request_id, "repaired": False, "updated": 0, "reason": "missing_document_id"}

    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        params: list[Any] = [document_id, request_id]
        llm_where = ["request_id = %s", "document_id IS NULL"]
        cost_where = ["(task_id = %s OR request_id = %s)", "document_id IS NULL"]
        cost_params: list[Any] = [document_id, request_id, request_id]
        if kb_id:
            llm_where.append("kb_id = %s")
            params.append(kb_id)
            cost_where.append("kb_id = %s")
            cost_params.append(kb_id)
        with conn.cursor() as cur:
            cur.execute(
                f"""
                UPDATE kb_llm_call_logs
                SET document_id = NULLIF(%s, '')::uuid
                WHERE {' AND '.join(llm_where)}
                """,
                tuple(params),
            )
            llm_updated = int(getattr(cur, "rowcount", 0) or 0)
            cur.execute(
                f"""
                UPDATE kb_processing_cost_events
                SET document_id = NULLIF(%s, '')::uuid
                WHERE {' AND '.join(cost_where)}
                """,
                tuple(cost_params),
            )
            event_updated = int(getattr(cur, "rowcount", 0) or 0)
        conn.commit()
        updated = llm_updated + event_updated
        return {
            "requestId": request_id,
            "documentId": document_id,
            "repaired": updated > 0,
            "updated": updated,
            "llmUpdated": llm_updated,
            "eventUpdated": event_updated,
            "reason": "updated" if updated > 0 else "nothing_to_update",
        }
    except Exception:
        if hasattr(conn, "rollback"):
            conn.rollback()
        raise
    finally:
        conn.close()


def append_audit_log(record: AuditLogRecord) -> bool:
    """Append a sanitized audit event. Audit failure must not break the action."""
    try:
        conn = get_db_connection()
    except Exception:
        return False

    identity = record.identity
    api_key_id = record.api_key_id or _api_key_id_from_identity(identity)
    try:
        ensure_db_schema(conn)
        with conn.cursor() as cur:
            cur.execute(
                """
                INSERT INTO kb_audit_logs(
                    request_id, tenant_id, actor_id, actor_name, actor_source,
                    action, resource_type, resource_id, kb_id, api_key_id,
                    outcome, risk_level, summary, metadata
                )
                VALUES(
                    %s, %s, %s, %s, %s,
                    %s, %s, %s, %s, %s,
                    %s, %s, %s, %s::jsonb
                )
                """,
                (
                    record.request_id,
                    identity.tenant_id if identity and identity.enforce_access else None,
                    identity.user_id if identity and identity.enforce_access else None,
                    _identity_actor_name(identity),
                    identity.source if identity else None,
                    record.action,
                    record.resource_type,
                    record.resource_id,
                    record.kb_id,
                    api_key_id,
                    record.outcome,
                    record.risk_level,
                    _summary(record.summary, 300),
                    json.dumps(_sanitize_audit_metadata(record.metadata or {}), ensure_ascii=False),
                ),
            )
        conn.commit()
        return True
    except Exception:
        if hasattr(conn, "rollback"):
            conn.rollback()
        return False
    finally:
        conn.close()


def fetch_rag_query_logs(
    *,
    tenant_id: str | None = None,
    kb_id: str | None = None,
    request_id: str | None = None,
    actor_id: str | None = None,
    api_key_id: str | None = None,
    pipeline_domain: str | None = None,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
    limit: int = 50,
    max_limit: int = 200,
) -> list[dict[str, Any]]:
    """Return sanitized query logs for the console log center."""
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where: list[str] = []
        params: list[Any] = []
        for column, value in (
            ("tenant_id", tenant_id),
            ("kb_id", kb_id),
            ("request_id", request_id),
            ("actor_id", actor_id),
            ("api_key_id", api_key_id),
            ("pipeline_domain", pipeline_domain),
        ):
            if value:
                where.append(f"{column} = %s")
                params.append(value)
        if start_at:
            where.append("created_at >= %s")
            params.append(start_at)
        if end_at:
            where.append("created_at <= %s")
            params.append(end_at)

        sql = """
            SELECT request_id, pipeline_domain, pipeline_stage, tenant_id, actor_id,
                   kb_id, api_key_id, query_hash, query_summary, answer_summary,
                   cannot_answer, relevance_score, faithfulness_score,
                   prompt_tokens, completion_tokens, total_tokens,
                   latency_ms, status, error_code, created_at
            FROM kb_rag_query_logs
        """
        if where:
            sql += " WHERE " + " AND ".join(where)
        sql += " ORDER BY created_at DESC LIMIT %s"
        params.append(max(1, min(int(limit or 50), max(1, int(max_limit or 200)))))

        with conn.cursor() as cur:
            cur.execute(sql, tuple(params))
            rows = cur.fetchall()

        return [_log_row_to_payload(row) for row in rows]
    finally:
        conn.close()


def export_rag_query_logs_csv(
    *,
    tenant_id: str | None = None,
    kb_id: str | None = None,
    request_id: str | None = None,
    actor_id: str | None = None,
    api_key_id: str | None = None,
    pipeline_domain: str | None = None,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
    limit: int = 10000,
) -> tuple[str, bytes]:
    rows = fetch_rag_query_logs(
        tenant_id=tenant_id,
        kb_id=kb_id,
        request_id=request_id,
        actor_id=actor_id,
        api_key_id=api_key_id,
        pipeline_domain=pipeline_domain,
        start_at=start_at,
        end_at=end_at,
        limit=limit,
        max_limit=100000,
    )
    filename = f"rag-query-logs-{datetime.utcnow().strftime('%Y%m%d%H%M%S')}.csv"
    return filename, _render_export_csv(rows)


def fetch_audit_logs(
    *,
    tenant_id: str | None = None,
    actor_id: str | None = None,
    action: str | None = None,
    resource_type: str | None = None,
    resource_id: str | None = None,
