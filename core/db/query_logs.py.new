def _processing_event_row_to_payload(row: tuple[Any, ...]) -> dict[str, Any]:
    metadata = row[32] or {}
    if isinstance(metadata, str):
        try:
            metadata = json.loads(metadata)
        except json.JSONDecodeError:
            metadata = {}
    return {
        "eventId": row[0],
        "eventType": row[1],
        "pipelineDomain": row[2],
        "pipelineStage": row[3],
        "featureName": row[4] or "",
        "taskId": row[5] or "",
        "requestId": row[6] or "",
        "usageTargetType": row[7] or "",
        "documentId": row[8] or "",
        "kbId": row[9] or "",
        "tenantId": row[10] or "",
        "actorId": row[11] or "",
        "actorSource": row[12] or "",
        "apiKeyId": row[13] or "",
        "appId": row[14] or "",
        "provider": row[15] or "",
        "modelName": row[16] or "",
        "externalJobId": row[17] or "",
        "metricValue": _decimal_float(row[18]) if row[18] is not None else None,
        "metricUnit": row[19] or "",
        "promptTokens": int(row[20] or 0),
        "completionTokens": int(row[21] or 0),
        "totalTokens": int(row[22] or 0),
        "durationMs": int(row[23] or 0),
        "status": row[24] or "success",
        "errorCode": row[25] or "",
        "estimatedCost": _decimal_float(row[26]) if row[26] is not None else None,
        "costCurrency": row[27] or "",
        "costSource": row[28] or "not_available",
        "llmCallLogId": int(row[29]) if row[29] is not None else None,
        "usageSource": row[30] or "runtime",
        "collectionStatus": row[31] or "recorded",
        "metadata": metadata if isinstance(metadata, dict) else {},
        "occurredAt": _iso(row[33]),
    }


def _app_usage_metric_row(row: tuple[Any, ...]) -> dict[str, Any]:
    request_count = int(row[0] or 0) if row else 0
    return {
        "requestCount": request_count,
        "promptTokens": int(row[1] or 0) if row else 0,
        "completionTokens": int(row[2] or 0) if row else 0,
        "totalTokens": int(row[3] or 0) if row else 0,
        "avgLatencyMs": round(float(row[4] or 0), 2) if row else 0,
        "errorCount": int(row[5] or 0) if row else 0,
        "successRate": round((request_count - int(row[5] or 0)) / request_count, 4) if request_count > 0 else 0,
        "lastCalledAt": _iso(row[6]) if row and len(row) > 6 else "",
    }


def _app_usage_group_row(
    row: tuple[Any, ...],
    id_key: str,
    name_key: str | None = None,
) -> dict[str, Any]:
    offset = 2 if name_key else 1
    payload = {
        id_key: row[0] or "",
        "requestCount": int(row[0 + offset] or 0),
        "promptTokens": int(row[1 + offset] or 0),
        "completionTokens": int(row[2 + offset] or 0),
        "totalTokens": int(row[3 + offset] or 0),
        "avgLatencyMs": round(float(row[4 + offset] or 0), 2),
        "errorCount": int(row[5 + offset] or 0),
        "lastCalledAt": _iso(row[6 + offset]),
    }
    if name_key:
        payload[name_key] = row[1] or ""
    return payload


