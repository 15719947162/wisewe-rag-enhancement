# 本文件按模块分组；每个变量上方都有用途说明。
# 修改配置值即可，注释不参与运行时读取。

# ── 通用 LLM 与向量化 ─────────────────────────────────────
# 通用 LLM API Key，用于默认文本模型调用。
LLM_API_KEY=sk-xxx
# 通用 LLM OpenAI-compatible API 地址。
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 解析后清洗是否启用大模型，默认 false 只走规则清洗，不产生清洗 Token。
LLM_CLEANER_ENABLED=false
LLM_CLEANER_MODEL=qwen-plus
LLM_CLEANER_BASE_URL=
LLM_CLEANER_API_KEY=
LLM_CLEANER_SYSTEM_PROMPT=
# 切片质量审核是否启用大模型，默认 false 只走规则质检，不产生质检 Token。
LLM_QUALITY_GATE_ENABLED=false
LLM_QUALITY_GATE_MODEL=qwen-plus
LLM_QUALITY_GATE_BASE_URL=
LLM_QUALITY_GATE_API_KEY=
LLM_QUALITY_GATE_MIN_SCORE=3
LLM_QUALITY_GATE_SYSTEM_PROMPT=
# 向量化模型名称。
LLM_EMBEDDING_MODEL=text-embedding-v3
# 向量化单批文本数量。
LLM_EMBEDDING_BATCH_SIZE=10
# 向量化 API 最大并发数。
LLM_EMBEDDING_MAX_CONCURRENCY=10
# 向量化 API 单批最大重试次数。
LLM_EMBEDDING_MAX_RETRIES=2
# 向量化单个 key 遇到限流后的换 key 重试次数。
LLM_EMBEDDING_KEY_RETRIES=1
# 向量化单个 key 遇到限流后的冷却时间（秒）。
LLM_EMBEDDING_KEY_COOLDOWN_SECONDS=30
# 在线问答 query embedding 进程内缓存 TTL（秒）。
RAG_QUERY_EMBEDDING_CACHE_TTL_SECONDS=1800
# 在线问答 query embedding 进程内缓存最大条目数。
RAG_QUERY_EMBEDDING_CACHE_MAX_SIZE=512
# 在线检索是否启用候选快照查询优化。
RAG_RETRIEVAL_SNAPSHOT=true

# ── 三层切片增强 ─────────────────────────────────────
# 入库可用模式；full 保持完整增强，basic/basic_ready 先跳过 hierarchical enhanced 层以更快进入基础可检索状态。
INGESTION_READY_MODE=full
# 三层切片增强执行模式。
HIERARCHICAL_ENHANCE_MODE=parallel_ordered
# 文本增强 worker 软上限。
HIERARCHICAL_TEXT_ENHANCE_WORKERS=16
# 表格增强 worker 软上限。
HIERARCHICAL_TABLE_ENHANCE_WORKERS=3
# 图片 / VL 增强 worker 软上限。
HIERARCHICAL_IMAGE_ENHANCE_WORKERS=4
# 三层切片增强全局最大外呼并发。
HIERARCHICAL_ENHANCE_MAX_CONCURRENCY=100
# 三层切片增强是否复用线程内 LLM client。
HIERARCHICAL_REUSE_LLM_CLIENTS=true
# 三层切片增强单个 key 遇到限流后的换 key 重试次数。
HIERARCHICAL_ENHANCE_KEY_RETRIES=1
# 三层切片增强单个 key 遇到限流后的冷却时间（秒）。
HIERARCHICAL_KEY_COOLDOWN_SECONDS=30

# ── 解析 Provider 与 MinerU ─────────────────────────────────────
# 当前 PDF 解析 Provider，可选 mineru / mineru_official / ali_document_mind。
PDF_PARSER_PROVIDER=mineru
# 解析 Provider 回退列表，多个值用逗号分隔；为空表示不回退。
PDF_PARSER_FALLBACKS=

# MinerU 官方精准解析 API；选择 PDF_PARSER_PROVIDER=mineru_official 时生效。
MINERU_OFFICIAL_API_BASE=https://mineru.net
MINERU_OFFICIAL_API_TOKEN=
MINERU_OFFICIAL_MODEL_VERSION=pipeline
MINERU_OFFICIAL_TIMEOUT=1800
MINERU_OFFICIAL_POLL_INTERVAL=3
MINERU_OFFICIAL_ENABLE_FORMULA=true
MINERU_OFFICIAL_ENABLE_TABLE=true
MINERU_OFFICIAL_LANGUAGE=ch
MINERU_OFFICIAL_IS_OCR=false
MINERU_OFFICIAL_EXTRA_FORMATS=
MINERU_OFFICIAL_NO_CACHE=false
MINERU_OFFICIAL_CACHE_TOLERANCE=900
MINERU_OFFICIAL_SUBMIT_RETRY_ATTEMPTS=3
MINERU_OFFICIAL_POLL_RETRY_ATTEMPTS=5
MINERU_OFFICIAL_SHARDING_ENABLED=true
MINERU_OFFICIAL_SHARDING_MIN_FILE_MB=180
MINERU_OFFICIAL_SHARDING_MIN_PAGES=201
MINERU_OFFICIAL_SHARDING_PAGES_PER_SHARD=20
MINERU_OFFICIAL_SHARDING_MAX_CONCURRENCY=6
MINERU_OFFICIAL_SHARDING_MAX_FILE_MB_PER_SHARD=30
MINERU_OFFICIAL_SHARDING_TEXT_SAMPLE_PAGES=5

# ── 阿里 Document Mind 解析 ─────────────────────────────────────
# Document Mind 解析专用 AK；留空时回退到 OSS_ACCESS_KEY_ID。
ALIYUN_DOCUMENT_MIND_ACCESS_KEY_ID=
# Document Mind 解析专用 SK；留空时回退到 OSS_ACCESS_KEY_SECRET。
ALIYUN_DOCUMENT_MIND_ACCESS_KEY_SECRET=
# Document Mind 服务地址，默认杭州地域。
ALIYUN_DOCUMENT_MIND_ENDPOINT=docmind-api.cn-hangzhou.aliyuncs.com
# Document Mind 单次解析超时（秒）。
ALIYUN_DOCUMENT_MIND_TIMEOUT=1800
# Document Mind 轮询解析结果的间隔（秒）。
ALIYUN_DOCUMENT_MIND_POLL_INTERVAL=3
# Document Mind 输出格式，当前用于 markdown 与 visualLayoutInfo。
ALIYUN_DOCUMENT_MIND_OUTPUT_FORMAT=markdown,visualLayoutInfo
# Document Mind 多 AK/SK 轮转池，格式 ak1:sk1,ak2:sk2。
ALIYUN_DOCUMENT_MIND_CREDENTIAL_POOL=
# Document Mind 单个 AK/SK 的最大在途解析请求数；建议保持 1，通过真实 AK/SK 组数扩大解析并发。
ALIYUN_DOCUMENT_MIND_MAX_INFLIGHT_PER_KEY=1
# Document Mind 单个 AK/SK 遇到限流后的换 key 重试次数。
ALIYUN_DOCUMENT_MIND_KEY_RETRIES=1
# Document Mind 单个 AK/SK 遇到限流后的冷却时间（秒）。
ALIYUN_DOCUMENT_MIND_KEY_COOLDOWN_SECONDS=60
# Document Mind 无历史延迟 key 的同时探测上限，避免多 AK/SK 冷启动时一次性放大隐式慢尾。
ALIYUN_DOCUMENT_MIND_KEY_PROBE_CONCURRENCY=1
# Document Mind 是否启用 LLM / VLM 增强；当前快速解析档默认关闭，后续三层切片增强继续由本项目控制。
ALIYUN_DOCUMENT_MIND_LLM_ENHANCEMENT=false
# Document Mind 增强模式，例如 VLM。
ALIYUN_DOCUMENT_MIND_ENHANCEMENT_MODE=VLM
# Document Mind 版面增强步长。
ALIYUN_DOCUMENT_MIND_LAYOUT_STEP_SIZE=3000
# Document Mind 拉取解析结果的最大重试次数。
ALIYUN_DOCUMENT_MIND_RESULT_FETCH_RETRIES=2
# Document Mind success 但结果为空时的重试次数。
ALIYUN_DOCUMENT_MIND_EMPTY_RESULT_RETRIES=1
# Document Mind 空结果重试间隔（秒）。
ALIYUN_DOCUMENT_MIND_EMPTY_RESULT_RETRY_DELAY=2
# Document Mind 慢分片投机重发开关；默认关闭，仅建议在 parse-only benchmark 中验证。
ALIYUN_DOCUMENT_MIND_HEDGED_SHARD_ENABLED=false
# Document Mind 分片超过该秒数仍未完成时，允许发起投机副本。
ALIYUN_DOCUMENT_MIND_HEDGE_AFTER_SECONDS=90
# Document Mind 每个慢分片最多额外投机副本次数。
ALIYUN_DOCUMENT_MIND_HEDGE_MAX_EXTRA_ATTEMPTS=1
# Document Mind 大文件分片解析开关。
ALIYUN_DOCUMENT_MIND_SHARDING_ENABLED=true
# Document Mind 触发分片的最小文件大小（MB）。
ALIYUN_DOCUMENT_MIND_SHARDING_MIN_FILE_MB=150
# Document Mind 触发分片的最小页数。
ALIYUN_DOCUMENT_MIND_SHARDING_MIN_PAGES=50
# Document Mind 每个 PDF 分片包含的页数。
ALIYUN_DOCUMENT_MIND_SHARDING_PAGES_PER_SHARD=33
# Document Mind 分片解析最大并发数；仅影响解析 submit/poll/result，不调整清洗、切片、向量化或入库逻辑。
ALIYUN_DOCUMENT_MIND_SHARDING_MAX_CONCURRENCY=4
# Document Mind 自适应分片时允许收敛到的最小页数，避免 shard 过碎。
ALIYUN_DOCUMENT_MIND_SHARDING_MIN_PAGES_PER_SHARD=20
# Document Mind 自适应分片目标波次数；实际并发仍受 shard 数和 key 池容量约束。
ALIYUN_DOCUMENT_MIND_SHARDING_TARGET_WAVES=2
# Document Mind 分片前用于文本抽样判断的页数。
ALIYUN_DOCUMENT_MIND_SHARDING_TEXT_SAMPLE_PAGES=5
# Document Mind 是否启用复杂度感知分片；同教材 A/B 显示当前固定分片更快，默认关闭，仅用于显式实验。
ALIYUN_DOCUMENT_MIND_WEIGHTED_SHARDING_ENABLED=false
# Document Mind 是否优先提交复杂度较高的 shard；需配合复杂度分片显式验证，默认关闭。
ALIYUN_DOCUMENT_MIND_HEAVY_SHARD_FIRST=false
ALIYUN_DOCUMENT_MIND_SHARD_SAVE_GARBAGE=1
ALIYUN_DOCUMENT_MIND_SHARD_SAVE_DEFLATE=true

# ── 阿里云 OSS 存储 ─────────────────────────────────────
# 阿里云 OSS AccessKey ID，用于源文件 / 解析文件上传。
OSS_ACCESS_KEY_ID=
# 阿里云 OSS AccessKey Secret，用于源文件 / 解析文件上传。
OSS_ACCESS_KEY_SECRET=
# 阿里云 OSS endpoint。
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# 阿里云 OSS bucket 名称。
OSS_BUCKET=

# ── PostgreSQL 与 pgvector ─────────────────────────────────────
# PostgreSQL / pgvector 主机地址。
PGVECTOR_HOST=127.0.0.1
# PostgreSQL / pgvector 端口。
PGVECTOR_PORT=5432
# PostgreSQL / pgvector 数据库名。
PGVECTOR_DB=rag_db
# PostgreSQL / pgvector 用户名。
PGVECTOR_USER=postgres
# PostgreSQL / pgvector 密码。
PGVECTOR_PASSWORD=
# pgvector 批量写入页大小。
PGVECTOR_WRITE_PAGE_SIZE=500
# pgvector 写入模式；copy 会通过临时表 + COPY 降低跨网络批量写入开销。
PGVECTOR_WRITE_MODE=copy

# ── 前端与内部 API ─────────────────────────────────────
# 浏览器访问后端 API 的 base URL。
NEXT_PUBLIC_API_BASE_URL=http://192.168.2.208:8001
# 容器 / 服务端内部访问后端 API 的 base URL。
INTERNAL_API_BASE_URL=http://backend:8000
# Docker 暴露到宿主机 / 局域网的后端端口；避开 C-Lodop 常用的 8000。
BACKEND_HOST_PORT=8001

# ── AI 基座 SSO 与控制台登录态 ─────────────────────────────────────
# AI 基座服务端内部接口根地址；RAG 后端用它调用 exchange / identity snapshot / delta。
AI_BASE_SSO_BASE_URL=
# 知识库在 AI 基座登记的 SSO client id。
AI_BASE_SSO_CLIENT_ID=rag-client
# 知识库在 AI 基座登记的 SSO client secret；只允许后端读取，不要写入前端 NEXT_PUBLIC_* 变量。
AI_BASE_SSO_CLIENT_SECRET=
# AI 基座回跳 RAG 后端的 callback 地址，需与 AI 基座租户端登记值完全一致。
AI_BASE_SSO_REDIRECT_URI=http://192.168.2.208:8001/api/auth/ai-base/callback
# RAG launch 生成 state/cookie 后，302 跳转到的 AI 基座浏览器 SSO 根地址。
# AI 基座页面上的“进入知识库”按钮应指向 RAG /api/auth/ai-base/launch，而不是直接发起 callback。
AI_BASE_SSO_LAUNCH_BASE_URL=
# RAG launch 跳向 AI 基座浏览器 SSO 的路径。
AI_BASE_SSO_LAUNCH_PATH=/sso
# SSO state 由 RAG 发起登录时生成一次性随机值并写入 HttpOnly cookie，不需要配置固定值。
# RAG 后端调用 AI 基座服务端接口的真实路径。
AI_BASE_SSO_EXCHANGE_PATH=/ai/system/internal/sso/exchange
# AI 基座当前用户身份刷新路径模板；`{userId}` 与 `tenant_id` 由知识库填充。
AI_BASE_SSO_USER_SNAPSHOT_PATH_TEMPLATE=/ai/system/internal/identity/snapshot/users/{userId}
# AI 基座身份增量同步路径；`last_sync_at` 由知识库填充。
AI_BASE_SSO_DELTA_PATH=/ai/system/internal/identity/snapshot/delta
# SSO 完成后跳回知识库控制台的 base URL。
KB_CONSOLE_BASE_URL=http://192.168.2.208:3000
# 知识库本地 HttpOnly session 有效期（秒）。
KB_SESSION_TTL_SECONDS=14400
# 是否允许旧的 X-KB-Tenant-Id / X-KB-User-Id 请求头兜底身份；生产切 SSO 后建议设为 false。
KB_LEGACY_HEADER_AUTH_ENABLED=true
# 是否启用 AI 基座身份 HTTP delta 后台同步调度；默认关闭，联调确认后再开启。
AI_BASE_IDENTITY_SYNC_ENABLED=false
# AI 基座身份 HTTP delta 后台同步间隔（秒）；程序会强制不低于 60 秒。
AI_BASE_IDENTITY_SYNC_INTERVAL_SECONDS=300
# 后端启动时是否立即执行一次身份 delta 同步；默认关闭，避免冷启动时阻塞或打到未就绪的 AI 基座。
AI_BASE_IDENTITY_SYNC_RUN_ON_STARTUP=false
# 允许携带 cookie 访问后端的控制台来源，多个 origin 用逗号分隔。
KB_CORS_ALLOW_ORIGINS=http://192.168.2.208:3000,http://127.0.0.1:3000,http://localhost:3000
# 允许浏览器跨域预检的请求头，需包含前端身份头和 OpenAPI 鉴权头。
KB_CORS_ALLOW_HEADERS=Accept,Accept-Language,Authorization,Content-Language,Content-Type,X-API-Key,X-KB-Tenant-Id,X-KB-User-Id,X-Requested-With

# ── Docker 镜像与包镜像源 ─────────────────────────────────────
# Docker 构建使用的 Python 基础镜像。
PYTHON_IMAGE=m.daocloud.io/docker.io/library/python:3.11-slim
# Docker 构建使用的 Node.js 基础镜像。
NODE_IMAGE=m.daocloud.io/docker.io/library/node:22-alpine
# pip 包安装镜像源。
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple
# pip 镜像源可信主机。
PIP_TRUSTED_HOST=mirrors.aliyun.com
# npm 包安装镜像源。
NPM_REGISTRY=https://registry.npmmirror.com

# ── 可选代理（默认不启用，避免容器继承宿主机代理导致内网服务不可达） ──
# Docker 容器内 HTTP 代理；需要时再取消注释。
# HTTP_PROXY=http://host.docker.internal:7890
# Docker 容器内 HTTPS 代理；需要时再取消注释。
# HTTPS_PROXY=http://host.docker.internal:7890
# 不走代理的地址。
# NO_PROXY=localhost,127.0.0.1,backend,redis
