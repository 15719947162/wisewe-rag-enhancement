    end_at: datetime | None = None,
    limit: int = 50,
    max_limit: int = 200,
) -> list[dict[str, Any]]:
    """Return sanitized audit events for governance log views."""
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where: list[str] = []
        params: list[Any] = []
        for column, value in (
            ("tenant_id", tenant_id),
            ("actor_id", actor_id),
            ("action", action),
            ("resource_type", resource_type),
            ("resource_id", resource_id),
            ("request_id", request_id),
            ("kb_id", kb_id),
            ("outcome", outcome),
        ):
            if value:
                where.append(f"{column} = %s")
                params.append(value)
        if start_at:
            where.append("created_at >= %s")
            params.append(start_at)
        if end_at:
            where.append("created_at <= %s")
            params.append(end_at)

        sql = """
            SELECT id, request_id, tenant_id, actor_id, actor_name, actor_source,
                   action, resource_type, resource_id, kb_id, api_key_id,
                   outcome, risk_level, summary, metadata, created_at
            FROM kb_audit_logs
        """
        if where:
            sql += " WHERE " + " AND ".join(where)
        sql += " ORDER BY created_at DESC, id DESC LIMIT %s"
