def fetch_project_cost_estimates_for_identity(
    *,
    limit: int = 20,
    tenant_id: str | None = None,
    include_all_tenants: bool = False,
    visible_kb_ids: list[str] | None = None,
    task_id: str | None = None,
    kb_id: str | None = None,
    document_id: str | None = None,
    pipeline_domain: str | None = None,
    pipeline_stage: str | None = None,
    event_type: str | None = None,
    provider: str | None = None,
    cost_source: str | None = None,
    api_key_id: str | None = None,
    app_id: str | None = None,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> dict[str, Any]:
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        where, params = _processing_cost_filters(
            table_alias="e",
            tenant_id=tenant_id,
            include_all_tenants=include_all_tenants,
            visible_kb_ids=visible_kb_ids,
            task_id=task_id,
            kb_id=kb_id,
            document_id=document_id,
            pipeline_domain=pipeline_domain,
            pipeline_stage=pipeline_stage,
            event_type=event_type,
            provider=provider,
            api_key_id=api_key_id,
            app_id=app_id,
            start_at=start_at,
            end_at=end_at,
        )
        where.append(_project_cost_event_predicate("e"))
        if cost_source:
            where.append("e.cost_source = %s")
            params.append(cost_source)
        where_sql = f"WHERE {' AND '.join(where)}"
        capped_limit = max(1, min(int(limit or 20), 100))
        with conn.cursor() as cur:
            cur.execute(
                f"""
                SELECT
                    COUNT(*) AS event_count,
                    COALESCE(SUM(e.estimated_cost), 0) AS estimated_cost,
                    COUNT(e.estimated_cost) AS cost_available_count,
                    COUNT(*) FILTER (WHERE e.estimated_cost IS NULL) AS cost_unavailable_count,
                    COALESCE(MAX(e.cost_currency), '') AS cost_currency,
                    COUNT(*) FILTER (WHERE e.cost_source = 'estimated_parse_rate') AS parse_event_count,
                    COALESCE(SUM(e.estimated_cost) FILTER (WHERE e.cost_source = 'estimated_parse_rate'), 0) AS parse_estimated_cost,
                    COUNT(*) FILTER (WHERE e.cost_source = 'estimated_oss_rate') AS oss_event_count,
                    COALESCE(SUM(e.estimated_cost) FILTER (WHERE e.cost_source = 'estimated_oss_rate'), 0) AS oss_estimated_cost,
                    COALESCE(SUM(e.metric_value) FILTER (
                        WHERE e.event_type = 'parse_provider' AND e.metric_unit IN ('page', 'pages')
                    ), 0) AS parse_pages,
                    COALESCE(SUM(e.metric_value) FILTER (
                        WHERE (e.event_type LIKE 'oss_%%' OR e.provider = 'oss') AND e.metric_unit IN ('byte', 'bytes')
                    ), 0) AS oss_bytes,
                    MIN(e.occurred_at) AS first_occurred_at,
                    MAX(e.occurred_at) AS last_occurred_at
                FROM kb_processing_cost_events e
                {where_sql}
                """,
                tuple(params),
            )
            overall = _project_cost_overall_row(cur.fetchone())

            cur.execute(
                f"""
                SELECT
                    e.cost_source,
                    COALESCE(MAX(e.cost_currency), '') AS cost_currency,
                    COUNT(*) AS event_count,
                    COUNT(e.estimated_cost) AS cost_available_count,
                    COUNT(*) FILTER (WHERE e.estimated_cost IS NULL) AS cost_unavailable_count,
                    COALESCE(SUM(e.estimated_cost), 0) AS estimated_cost,
                    MIN(e.occurred_at) AS first_occurred_at,
                    MAX(e.occurred_at) AS last_occurred_at
                FROM kb_processing_cost_events e
                {where_sql}
                GROUP BY e.cost_source
                ORDER BY estimated_cost DESC, event_count DESC, e.cost_source ASC
                """,
                tuple(params),
            )
            by_cost_source = [_project_cost_source_row_to_payload(row) for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    e.event_type,
                    e.pipeline_stage,
                    COALESCE(e.provider, '') AS provider,
                    COALESCE(e.metric_unit, '') AS metric_unit,
                    COUNT(*) AS event_count,
                    COUNT(e.estimated_cost) AS cost_available_count,
                    COUNT(*) FILTER (WHERE e.estimated_cost IS NULL) AS cost_unavailable_count,
                    COALESCE(SUM(e.estimated_cost), 0) AS estimated_cost,
                    COALESCE(SUM(e.metric_value), 0) AS metric_value,
                    MAX(e.occurred_at) AS last_occurred_at
                FROM kb_processing_cost_events e
                {where_sql}
                GROUP BY e.event_type, e.pipeline_stage, provider, metric_unit
                ORDER BY estimated_cost DESC, event_count DESC, last_occurred_at DESC
                """,
                tuple(params),
            )
            by_event_type = [_project_cost_event_type_row_to_payload(row) for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    COALESCE(e.task_id, e.request_id, '') AS task_bucket,
                    MAX(e.request_id) AS request_id,
                    MAX(e.kb_id) AS kb_id,
                    COUNT(*) AS event_count,
                    COUNT(e.estimated_cost) AS cost_available_count,
                    COUNT(*) FILTER (WHERE e.estimated_cost IS NULL) AS cost_unavailable_count,
                    COALESCE(SUM(e.estimated_cost), 0) AS estimated_cost,
                    MAX(e.occurred_at) AS last_occurred_at
                FROM kb_processing_cost_events e
                {where_sql}
                    AND (e.task_id IS NOT NULL OR e.request_id IS NOT NULL)
                GROUP BY task_bucket
                ORDER BY estimated_cost DESC, last_occurred_at DESC, event_count DESC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            by_task = [_project_cost_task_row_to_payload(row) for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    e.document_id::text AS document_id,
                    MAX(e.kb_id) AS kb_id,
                    MAX(COALESCE(d.filename, '')) AS filename,
                    COUNT(*) AS event_count,
                    COUNT(e.estimated_cost) AS cost_available_count,
                    COUNT(*) FILTER (WHERE e.estimated_cost IS NULL) AS cost_unavailable_count,
                    COALESCE(SUM(e.estimated_cost), 0) AS estimated_cost,
                    MAX(e.occurred_at) AS last_occurred_at
                FROM kb_processing_cost_events e
                LEFT JOIN documents d ON e.document_id = d.id
                {where_sql}
                    AND e.document_id IS NOT NULL
                GROUP BY e.document_id
                ORDER BY estimated_cost DESC, last_occurred_at DESC, event_count DESC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            by_document = [_project_cost_document_row_to_payload(row) for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    e.event_id::text, e.event_type, e.pipeline_domain, e.pipeline_stage, e.feature_name,
                    e.task_id, e.request_id, e.usage_target_type, e.document_id::text,
                    e.kb_id, e.tenant_id, e.actor_id, e.actor_source, e.api_key_id, e.app_id,
                    e.provider, e.model_name, e.external_job_id,
                    e.metric_value, e.metric_unit,
                    e.prompt_tokens, e.completion_tokens, e.total_tokens, e.duration_ms,
                    e.status, e.error_code, e.estimated_cost, e.cost_currency, e.cost_source,
                    e.llm_call_log_id, e.usage_source, e.collection_status, e.metadata, e.occurred_at
                FROM kb_processing_cost_events e
                {where_sql}
                ORDER BY e.occurred_at DESC, e.created_at DESC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            recent_events = [_processing_event_row_to_payload(row) for row in cur.fetchall()]
        return {
            "source": "kb_processing_cost_events",
            "ledger": "project_cost_estimates",
            "scope": "all_tenants" if include_all_tenants else ("tenant" if tenant_id else "unscoped"),
            "filters": {
                "taskId": task_id or "",
                "kbId": kb_id or "",
                "documentId": document_id or "",
                "pipelineDomain": pipeline_domain or "",
                "pipelineStage": pipeline_stage or "",
                "eventType": event_type or "",
                "provider": provider or "",
                "costSource": cost_source or "",
                "apiKeyId": api_key_id or "",
                "appId": app_id or "",
                "startAt": _iso(start_at) if start_at else "",
                "endAt": _iso(end_at) if end_at else "",
            },
            "costModel": {
                "kind": "project_estimate",
                "includedCostSources": ["estimated_parse_rate", "estimated_oss_rate", "missing_processing_rate", "not_available"],
                "excluded": ["model_llm_call_costs"],
            },
            "overall": overall,
            "byCostSource": by_cost_source,
            "byEventType": by_event_type,
            "byTask": by_task,
            "byDocument": by_document,
            "recentEvents": recent_events,
        }
    finally:
        conn.close()


def _fetch_processing_cost_detail_for_identity(
    *,
    detail_type: str,
    detail_id: str,
    tenant_id: str | None,
    include_all_tenants: bool,
    visible_kb_ids: list[str] | None,
    limit: int,
) -> dict[str, Any]:
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        if detail_type == "document":
            where, params = _processing_cost_filters(
                tenant_id=tenant_id,
                include_all_tenants=include_all_tenants,
                visible_kb_ids=visible_kb_ids,
                document_id=detail_id,
            )
        else:
            where, params = _processing_cost_filters(
                tenant_id=tenant_id,
                include_all_tenants=include_all_tenants,
                visible_kb_ids=visible_kb_ids,
                task_id=detail_id,
            )
        where_sql = f"WHERE {' AND '.join(where)}"
        capped_limit = max(1, min(int(limit or 100), 200))
        with conn.cursor() as cur:
            cur.execute(
                f"""
                SELECT
                    COUNT(*) AS event_count,
                    COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(total_tokens), 0) AS total_tokens,
                    COALESCE(SUM(duration_ms), 0) AS duration_ms_sum,
                    COUNT(*) FILTER (WHERE status <> 'success') AS error_count,
                    COALESCE(SUM(estimated_cost), 0) AS estimated_cost
                FROM kb_processing_cost_events
                {where_sql}
                """,
                tuple(params),
            )
            overall = _processing_cost_overall_row(cur.fetchone())
            cur.execute(
                f"""
                SELECT
                    COALESCE(SUM(estimated_cost), 0) AS total_estimated_cost,
                    COUNT(estimated_cost) AS cost_available_count,
                    COUNT(*) FILTER (WHERE estimated_cost IS NULL) AS cost_unavailable_count,
                    COALESCE(MAX(cost_currency), '') AS cost_currency,
                    COUNT(*) FILTER (WHERE llm_call_log_id IS NOT NULL) AS model_event_count,
                    COALESCE(SUM(estimated_cost) FILTER (WHERE llm_call_log_id IS NOT NULL), 0) AS model_estimated_cost,
                    COUNT(estimated_cost) FILTER (WHERE llm_call_log_id IS NOT NULL) AS model_cost_available_count,
                    COUNT(*) FILTER (WHERE llm_call_log_id IS NOT NULL AND estimated_cost IS NULL) AS model_cost_unavailable_count,
                    COUNT(*) FILTER (WHERE llm_call_log_id IS NULL AND event_type = 'parse_provider') AS parse_event_count,
                    COALESCE(SUM(estimated_cost) FILTER (WHERE llm_call_log_id IS NULL AND event_type = 'parse_provider'), 0) AS parse_estimated_cost,
                    COUNT(estimated_cost) FILTER (WHERE llm_call_log_id IS NULL AND event_type = 'parse_provider') AS parse_cost_available_count,
                    COUNT(*) FILTER (WHERE llm_call_log_id IS NULL AND event_type = 'parse_provider' AND estimated_cost IS NULL) AS parse_cost_unavailable_count,
                    COUNT(*) FILTER (
                        WHERE llm_call_log_id IS NULL AND (event_type LIKE 'oss_%%' OR provider = 'oss')
                    ) AS oss_event_count,
                    COALESCE(SUM(estimated_cost) FILTER (
                        WHERE llm_call_log_id IS NULL AND (event_type LIKE 'oss_%%' OR provider = 'oss')
                    ), 0) AS oss_estimated_cost,
                    COUNT(estimated_cost) FILTER (
                        WHERE llm_call_log_id IS NULL AND (event_type LIKE 'oss_%%' OR provider = 'oss')
                    ) AS oss_cost_available_count,
                    COUNT(*) FILTER (
                        WHERE llm_call_log_id IS NULL AND (event_type LIKE 'oss_%%' OR provider = 'oss') AND estimated_cost IS NULL
                    ) AS oss_cost_unavailable_count,
                    COUNT(*) FILTER (
                        WHERE NOT (
                            llm_call_log_id IS NOT NULL
                            OR (llm_call_log_id IS NULL AND event_type = 'parse_provider')
                            OR (llm_call_log_id IS NULL AND (event_type LIKE 'oss_%%' OR provider = 'oss'))
                        )
                    ) AS other_event_count,
                    COALESCE(SUM(estimated_cost) FILTER (
                        WHERE NOT (
                            llm_call_log_id IS NOT NULL
                            OR (llm_call_log_id IS NULL AND event_type = 'parse_provider')
                            OR (llm_call_log_id IS NULL AND (event_type LIKE 'oss_%%' OR provider = 'oss'))
                        )
                    ), 0) AS other_estimated_cost,
                    COUNT(estimated_cost) FILTER (
                        WHERE NOT (
                            llm_call_log_id IS NOT NULL
                            OR (llm_call_log_id IS NULL AND event_type = 'parse_provider')
                            OR (llm_call_log_id IS NULL AND (event_type LIKE 'oss_%%' OR provider = 'oss'))
                        )
                    ) AS other_cost_available_count,
                    COUNT(*) FILTER (
                        WHERE NOT (
                            llm_call_log_id IS NOT NULL
                            OR (llm_call_log_id IS NULL AND event_type = 'parse_provider')
                            OR (llm_call_log_id IS NULL AND (event_type LIKE 'oss_%%' OR provider = 'oss'))
                        ) AND estimated_cost IS NULL
                    ) AS other_cost_unavailable_count
                FROM kb_processing_cost_events
                {where_sql}
                """,
                tuple(params),
            )
            cost_breakdown = _processing_cost_breakdown_row(cur.fetchone())
            cur.execute(
                f"""
                SELECT
                    pipeline_stage,
                    event_type,
                    feature_name,
                    COUNT(*) AS event_count,
                    COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(total_tokens), 0) AS total_tokens,
                    COALESCE(SUM(duration_ms), 0) AS duration_ms_sum,
                    COUNT(*) FILTER (WHERE status <> 'success') AS error_count,
                    COALESCE(SUM(estimated_cost), 0) AS estimated_cost,
                    MAX(occurred_at) AS last_occurred_at
                FROM kb_processing_cost_events
                {where_sql}
                GROUP BY pipeline_stage, event_type, feature_name
                ORDER BY last_occurred_at DESC, duration_ms_sum DESC, total_tokens DESC
                """,
                tuple(params),
            )
            stages = [_processing_stage_row_to_payload(row) for row in cur.fetchall()]
            cur.execute(
                f"""
                SELECT
                    event_id::text, event_type, pipeline_domain, pipeline_stage, feature_name,
                    task_id, request_id, usage_target_type, document_id::text,
                    kb_id, tenant_id, actor_id, actor_source, api_key_id, app_id,
                    provider, model_name, external_job_id,
                    metric_value, metric_unit,
                    prompt_tokens, completion_tokens, total_tokens, duration_ms,
                    status, error_code, estimated_cost, cost_currency, cost_source,
                    llm_call_log_id, usage_source, collection_status, metadata, occurred_at
                FROM kb_processing_cost_events
                {where_sql}
                ORDER BY occurred_at DESC, created_at DESC
                LIMIT %s
                """,
                tuple(params + [capped_limit]),
            )
            events = [_processing_event_row_to_payload(row) for row in cur.fetchall()]
        return {
            "source": "kb_processing_cost_events",
            "detailType": detail_type,
            "id": detail_id,
            "scope": "all_tenants" if include_all_tenants else ("tenant" if tenant_id else "unscoped"),
            "overall": overall,
            "costBreakdown": cost_breakdown,
            "stages": stages,
            "events": events,
        }
    finally:
        conn.close()


def fetch_token_usage_summary_for_identity(
    *,
    limit: int = 10,
    tenant_id: str | None = None,
    include_all_tenants: bool = False,
    pipeline_domain: str | None = None,
) -> dict[str, Any]:
    conn = get_db_connection()
    try:
        ensure_db_schema(conn)
        with conn.cursor() as cur:
            llm_where: list[str] = []
            llm_params: list[Any] = []
            rag_where: list[str] = []
            rag_params: list[Any] = []
            if tenant_id and not include_all_tenants:
                llm_where.append("tenant_id = %s")
                llm_params.append(tenant_id)
                rag_where.append("tenant_id = %s")
                rag_params.append(tenant_id)
            if pipeline_domain:
                llm_where.append("pipeline_domain = %s")
                llm_params.append(pipeline_domain)
                rag_where.append("pipeline_domain = %s")
                rag_params.append(pipeline_domain)

            llm_where_sql = f" WHERE {' AND '.join(llm_where)}" if llm_where else ""
            rag_where_sql = f" WHERE {' AND '.join(rag_where)}" if rag_where else ""

            capped_limit = max(1, min(int(limit or 10), 50))

            cur.execute(
                f"""
                SELECT
                    COUNT(*) AS request_count,
                    COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(total_tokens), 0) AS total_tokens,
                    COALESCE(AVG(NULLIF(latency_ms, 0)), 0) AS avg_latency_ms
                FROM kb_llm_call_logs
                {llm_where_sql}
                """,
                tuple(llm_params),
            )
            overall = _aggregate_row(cur.fetchone())

            cur.execute(
                f"""
                SELECT pipeline_domain,
                       COUNT(*) AS request_count,
                       COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                       COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                       COALESCE(SUM(total_tokens), 0) AS total_tokens,
                       COALESCE(AVG(NULLIF(latency_ms, 0)), 0) AS avg_latency_ms
                FROM kb_llm_call_logs
                {llm_where_sql}
                GROUP BY pipeline_domain
                ORDER BY total_tokens DESC, request_count DESC, pipeline_domain ASC
                """,
                tuple(llm_params),
            )
            by_pipeline = [_aggregate_row(row, "pipelineDomain") for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT kb_id,
                       COUNT(*) AS request_count,
                       COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                       COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                       COALESCE(SUM(total_tokens), 0) AS total_tokens,
                       COALESCE(AVG(NULLIF(latency_ms, 0)), 0) AS avg_latency_ms
                FROM kb_llm_call_logs
                {llm_where_sql}
                GROUP BY kb_id
                ORDER BY total_tokens DESC, request_count DESC, kb_id ASC
                LIMIT %s
                """,
                tuple(llm_params + [capped_limit]),
            )
            by_kb = [_aggregate_row(row, "kbId") for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT COALESCE(api_key_id, 'console') AS api_key_bucket,
                       COUNT(*) AS request_count,
                       COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                       COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                       COALESCE(SUM(total_tokens), 0) AS total_tokens,
                       COALESCE(AVG(NULLIF(latency_ms, 0)), 0) AS avg_latency_ms
                FROM kb_llm_call_logs
                {llm_where_sql}
                GROUP BY api_key_bucket
                ORDER BY total_tokens DESC, request_count DESC, api_key_bucket ASC
                LIMIT %s
                """,
                tuple(llm_params + [capped_limit]),
            )
            by_api_key = [_aggregate_row(row, "apiKeyId") for row in cur.fetchall()]

            cur.execute(
                f"""
                SELECT
                    pipeline_stage,
                    feature_name,
                    COUNT(*) AS request_count,
                    COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(total_tokens), 0) AS total_tokens,
                    COALESCE(AVG(NULLIF(latency_ms, 0)), 0) AS avg_latency_ms,
                    MAX(created_at) AS last_called_at
                FROM kb_llm_call_logs
                {llm_where_sql}
                GROUP BY pipeline_stage, feature_name
                ORDER BY total_tokens DESC, request_count DESC, pipeline_stage ASC, feature_name ASC
                """,
                tuple(llm_params),
            )
            logged_stage_rows = cur.fetchall()

            cur.execute(
                f"""
                SELECT
                    id,
                    request_id,
                    pipeline_domain,
                    pipeline_stage,
                    feature_name,
                    provider,
                    model_name,
                    COALESCE(model_version, '') AS model_version,
                    prompt_tokens,
                    completion_tokens,
                    total_tokens,
                    latency_ms,
                    status,
                    error_code,
                    kb_id,
                    COALESCE(api_key_id, 'console') AS api_key_bucket,
                    created_at
                FROM kb_llm_call_logs
                {llm_where_sql}
                ORDER BY created_at DESC, id DESC
                LIMIT %s
                """,
                tuple(llm_params + [capped_limit]),
            )
            llm_calls = [_llm_call_row_to_payload(row) for row in cur.fetchall()]

            hourly_where: list[str] = ["hour_bucket >= NOW() - INTERVAL '24 hours'"]
            hourly_params: list[Any] = []
            if tenant_id and not include_all_tenants:
                hourly_where.append("tenant_id = %s")
                hourly_params.append(tenant_id)
            if pipeline_domain:
                hourly_where.append("pipeline_domain = %s")
                hourly_params.append(pipeline_domain)
            hourly_where_sql = f" WHERE {' AND '.join(hourly_where)}"
            hourly_limit = max(capped_limit, 24)
            cur.execute(
                f"""
                SELECT
                    hour_bucket,
                    pipeline_domain,
                    pipeline_stage,
                    feature_name,
                    COALESCE(SUM(request_count), 0) AS request_count,
                    COALESCE(SUM(prompt_tokens), 0) AS prompt_tokens,
                    COALESCE(SUM(completion_tokens), 0) AS completion_tokens,
                    COALESCE(SUM(total_tokens), 0) AS total_tokens,
                    COALESCE(SUM(latency_ms_sum), 0) AS latency_ms_sum,
                    COALESCE(SUM(error_count), 0) AS error_count,
                    COALESCE(SUM(estimated_cost), 0) AS estimated_cost
                FROM kb_token_usage_hourly
                {hourly_where_sql}
                GROUP BY hour_bucket, pipeline_domain, pipeline_stage, feature_name
                ORDER BY hour_bucket DESC, total_tokens DESC, pipeline_domain ASC, pipeline_stage ASC
                LIMIT %s
                """,
                tuple(hourly_params + [hourly_limit]),
            )
            hourly_usage = [_hourly_usage_row_to_payload(row) for row in cur.fetchall()]

            cost_where: list[str] = ["llm_call_log_id IS NOT NULL"]
            cost_params: list[Any] = []
            if tenant_id and not include_all_tenants:
                cost_where.append("tenant_id = %s")
                cost_params.append(tenant_id)
            if pipeline_domain:
                cost_where.append("pipeline_domain = %s")
                cost_params.append(pipeline_domain)
            cur.execute(
                f"""
                SELECT
                    COALESCE(SUM(estimated_cost), 0) AS estimated_cost,
                    COUNT(estimated_cost) AS cost_available_count,
                    COALESCE(MAX(cost_currency), '') AS cost_currency,
                    COALESCE(MAX(cost_source), '') AS cost_source
                FROM kb_processing_cost_events
                WHERE {' AND '.join(cost_where)}
                """,
                tuple(cost_params),
            )
            ledger_cost = _token_cost_ledger_row(cur.fetchone())

        pipeline_stages = _build_pipeline_stage_usage(logged_stage_rows, llm_calls, by_pipeline, pipeline_domain)
        cost_summary = _build_cost_summary(hourly_usage, overall, ledger_cost)
        quota = _token_quota_payload(overall)
        return {
            "source": "kb_llm_call_logs",
            "fallbackSource": "kb_rag_query_logs",
            "scope": "all_tenants" if include_all_tenants else ("tenant" if tenant_id else "unscoped"),
            "detailAvailable": bool(llm_calls),
            "overall": overall,
            "byPipeline": by_pipeline,
            "byKnowledgeBase": by_kb,
            "byApiKey": by_api_key,
            "pipelineStages": pipeline_stages,
            "llmCalls": llm_calls,
            "hourlyUsage": hourly_usage,
            "chartReady": bool(hourly_usage),
            "costSummary": cost_summary,
            "quota": quota,
            "quotaAlerts": _quota_alerts(quota),
        }
    finally:
        conn.close()


def _sha256(value: str) -> str:
    return hashlib.sha256((value or "").encode("utf-8")).hexdigest()


def _processing_cost_filters(
    *,
    table_alias: str = "",
    tenant_id: str | None = None,
    include_all_tenants: bool = False,
    visible_kb_ids: list[str] | None = None,
    task_id: str | None = None,
    request_id: str | None = None,
    document_id: str | None = None,
    kb_id: str | None = None,
    pipeline_domain: str | None = None,
    pipeline_stage: str | None = None,
    event_type: str | None = None,
    provider: str | None = None,
    model_name: str | None = None,
    api_key_id: str | None = None,
    app_id: str | None = None,
    start_at: datetime | None = None,
    end_at: datetime | None = None,
) -> tuple[list[str], list[Any]]:
    where: list[str] = []
    params: list[Any] = []
    column_prefix = f"{table_alias}." if table_alias else ""
    if tenant_id and not include_all_tenants:
        where.append(f"{column_prefix}tenant_id = %s")
        params.append(tenant_id)
    visible_ids = [str(item) for item in visible_kb_ids or [] if str(item)]
    if visible_ids:
        placeholders = ", ".join(["%s"] * len(visible_ids))
        where.append(f"{column_prefix}kb_id IN ({placeholders})")
        params.extend(visible_ids)
    if task_id:
        where.append(f"({column_prefix}task_id = %s OR {column_prefix}request_id = %s)")
        params.extend([task_id, task_id])
    if request_id:
        where.append(f"{column_prefix}request_id = %s")
        params.append(request_id)
    if document_id:
        where.append(f"{column_prefix}document_id = NULLIF(%s, '')::uuid")
        params.append(document_id)
    for column, value in (
        ("kb_id", kb_id),
        ("pipeline_domain", pipeline_domain),
        ("pipeline_stage", pipeline_stage),
        ("event_type", event_type),
        ("provider", provider),
        ("model_name", model_name),
        ("api_key_id", api_key_id),
        ("app_id", app_id),
    ):
        if value:
            where.append(f"{column_prefix}{column} = %s")
            params.append(value)
    if start_at:
        where.append(f"{column_prefix}occurred_at >= %s")
        params.append(start_at)
    if end_at:
        where.append(f"{column_prefix}occurred_at <= %s")
        params.append(end_at)
    if not where:
        where.append("1 = 1")
    return where, params


def _project_cost_event_predicate(table_alias: str = "") -> str:
    column_prefix = f"{table_alias}." if table_alias else ""
    return (
        f"{column_prefix}llm_call_log_id IS NULL "
        f"AND ({column_prefix}event_type = 'parse_provider' "
        f"OR {column_prefix}event_type LIKE 'oss_%%' "
        f"OR {column_prefix}provider = 'oss')"
    )


def _safe_slug(value: str | None, fallback: str, max_len: int) -> str:
    text = str(value or "").strip()
    if not text:
        text = fallback
    return text[:max_len]


def _request_as_task_id(request_id: str | None, usage_target_type: str | None) -> str | None:
    if _safe_slug(usage_target_type, "", 50) == "ingestion_task" and request_id:
        return request_id
    return None


def _usage_target_type(record: LlmCallLogRecord) -> str:
    if record.usage_target_type:
        return _safe_slug(record.usage_target_type, "request", 50)
    if record.pipeline_domain == "ingestion":
        return "ingestion_task"
    if record.pipeline_domain == "graph_rag":
        return "graph_rag_request"
    if record.pipeline_domain == "evaluation":
        return "evaluation_run"
    return "rag_request" if record.pipeline_domain in {"online_rag", "openapi"} else "request"


def _llm_event_type(record: LlmCallLogRecord) -> str:
    if record.event_type:
        return _safe_slug(record.event_type, "llm_enhancement", 50)
    stage = str(record.pipeline_stage or "").lower()
    if stage == "embedding":
        return "embedding"
    if stage == "rerank":
        return "rerank"
    if stage == "generation":
        return "rag_generation"
    if stage == "evaluation":
        return "evaluation"
    return "llm_enhancement"


def _decimal_or_none(value: int | float | Decimal | None) -> Decimal | None:
    if value is None:
        return None
    try:
        return Decimal(str(value)).quantize(Decimal("0.000001"))
    except (InvalidOperation, ValueError, TypeError):
        return None


def _safe_metadata_json(metadata: dict[str, Any]) -> str:
    return json.dumps(_sanitize_audit_metadata(metadata), ensure_ascii=False)


def _api_key_id_from_identity(identity: IdentityContext | None) -> str | None:
    if not identity or identity.source != "api_key":
        return None
    value = identity.username or identity.user_id or ""
    if value.startswith("api_key:"):
        return value.split(":", 1)[1]
    return value or None


def _identity_actor_name(identity: IdentityContext | None) -> str | None:
    if not identity or not identity.enforce_access:
        return None
    return identity.display_name or identity.username or identity.user_id


def _decimal_env(name: str, default: str = "0") -> Decimal:
    value = os.getenv(name, default)
    try:
        return Decimal(str(value or default))
    except (InvalidOperation, ValueError):
        return Decimal(default)


def _runtime_setting_value(name: str, default: Any = "") -> Any:
    try:
        value, _source = resolve_runtime_setting(name)
    except Exception:
        value = os.getenv(name, default)
    return default if value is None else value


def _decimal_runtime_setting(name: str, default: str = "0") -> Decimal:
    value = _runtime_setting_value(name, default)
    try:
        return Decimal(str(value or default))
    except (InvalidOperation, ValueError):
        return Decimal(default)


def _token_cost_currency() -> str:
    return str(_runtime_setting_value("KB_TOKEN_COST_CURRENCY", "CNY") or "CNY")


def _token_cost_rates() -> tuple[Decimal, Decimal, Decimal]:
    return (
        _decimal_runtime_setting("KB_TOKEN_COST_PER_1K_PROMPT"),
        _decimal_runtime_setting("KB_TOKEN_COST_PER_1K_COMPLETION"),
        _decimal_runtime_setting("KB_TOKEN_COST_PER_1K_TOTAL"),
    )


def _token_cost_source() -> str:
    return "configured_rate" if any(rate > 0 for rate in _token_cost_rates()) else "not_available"


def _token_model_rate_rules() -> list[dict[str, Any]]:
    raw_value = str(_runtime_setting_value("KB_TOKEN_MODEL_RATES_JSON", "") or "").strip()
    if not raw_value:
        return []
    try:
        parsed = json.loads(raw_value)
    except json.JSONDecodeError:
        return []
    if isinstance(parsed, dict) and isinstance(parsed.get("rates"), list):
        parsed = parsed["rates"]
    elif isinstance(parsed, dict):
        parsed = [parsed]
    if not isinstance(parsed, list):
        return []
    return [item for item in parsed if isinstance(item, dict)]


def _has_configured_model_rates() -> bool:
    return any(_token_rate_tuple_from_rule(rule) != (Decimal("0"), Decimal("0"), Decimal("0")) for rule in _token_model_rate_rules())


def _has_processing_cost_rates() -> bool:
    return bool(_processing_rate_rules("parse") or _processing_global_rates("oss"))


def _processing_cost_config() -> dict[str, Any]:
    raw_value = str(_runtime_setting_value("KB_PROCESSING_COST_RATES_JSON", "") or "").strip()
    if not raw_value:
        return {}
    try:
        parsed = json.loads(raw_value)
    except json.JSONDecodeError:
        return {}
    return parsed if isinstance(parsed, dict) else {}


def _processing_rate_rules(section: str) -> list[dict[str, Any]]:
    config = _processing_cost_config()
    value = config.get(section)
    if value is None and section == "parse":
        value = config.get("parser")
    if isinstance(value, dict) and isinstance(value.get("rates"), list):
        value = value["rates"]
    elif isinstance(value, dict):
        value = [value]
    if not isinstance(value, list):
        return []
    return [item for item in value if isinstance(item, dict)]


def _processing_global_rates(section: str) -> dict[str, Any]:
    value = _processing_cost_config().get(section)
    return value if isinstance(value, dict) else {}


def _pricing_key(value: Any) -> str:
    return str(value or "").strip().lower()


def _pricing_text(rule: dict[str, Any], *keys: str, default: str = "") -> str:
    for key in keys:
        value = rule.get(key)
        if value is not None and str(value).strip():
            return str(value).strip()
    return default


def _pricing_decimal(rule: dict[str, Any], *keys: str) -> Decimal:
    for key in keys:
        value = rule.get(key)
        if value is None or str(value).strip() == "":
            continue
        try:
            decimal_value = Decimal(str(value))
        except (InvalidOperation, ValueError):
            continue
        if decimal_value > 0:
            return decimal_value
    return Decimal("0")


def _token_rate_tuple_from_rule(rule: dict[str, Any]) -> tuple[Decimal, Decimal, Decimal]:
    return (
        _pricing_decimal(rule, "promptPer1k", "prompt_per_1k", "inputPer1k", "input_per_1k"),
        _pricing_decimal(
            rule,
            "completionPer1k",
            "completion_per_1k",
            "outputPer1k",
            "output_per_1k",
        ),
        _pricing_decimal(rule, "totalPer1k", "total_per_1k", "pricePer1k", "price_per_1k"),
    )


def _estimate_processing_cost(record: ProcessingCostEventRecord) -> ProcessingCostEstimate:
    event_type = _pricing_key(record.event_type)
    provider = _pricing_key(record.provider)
    if event_type == "parse_provider":
        return _estimate_parse_processing_cost(record)
    if event_type.startswith("oss_") or provider == "oss":
        return _estimate_oss_processing_cost(record)
    return ProcessingCostEstimate(None, None, record.cost_source or "not_available")


def _estimate_parse_processing_cost(record: ProcessingCostEventRecord) -> ProcessingCostEstimate:
    rules = _processing_rate_rules("parse")
    if not rules:
        return ProcessingCostEstimate(None, None, "not_available")
    provider = _pricing_key(record.provider)
    event_type = _pricing_key(record.event_type)
    best: tuple[int, int, dict[str, Any], str, Decimal, Decimal] | None = None
    for index, rule in enumerate(rules):
        rule_provider = _pricing_key(_pricing_text(rule, "provider", default="*") or "*")
        if rule_provider not in {"", "*", provider}:
            continue
        rule_event = _pricing_key(_pricing_text(rule, "eventType", "event_type", default="*") or "*")
        if rule_event not in {"", "*", event_type}:
            continue
        if not _processing_rule_metadata_matches(rule, record):
            continue
        unit = _pricing_key(_pricing_text(rule, "unit", "metricUnit", "metric_unit", default="page") or "page")
        quantity = _parse_cost_quantity(record, unit)
        if quantity <= 0:
            continue
        price = _parse_cost_unit_price(rule, unit)
        if price <= 0:
            continue
        score = 0
        if rule_provider and rule_provider != "*":
            score += 8
        if rule_event and rule_event != "*":
            score += 2
        if _processing_rule_has_metadata_conditions(rule):
            score += 16
        if best is None or score > best[0] or (score == best[0] and index < best[1]):
            best = (score, index, rule, unit, quantity, price)
    if best is None:
        return ProcessingCostEstimate(None, _token_cost_currency(), "missing_processing_rate")

    rule = best[2]
    unit = best[3]
    quantity = best[4]
    price = best[5]
    currency = _pricing_text(rule, "currency", default=_token_cost_currency())
    cost = (quantity * price).quantize(Decimal("0.000001"))
    return ProcessingCostEstimate(
        cost,
        currency,
        "estimated_parse_rate",
        {
            "source": "KB_PROCESSING_COST_RATES_JSON",
            "type": "parse",
            "provider": _pricing_text(rule, "provider", default=record.provider or "*"),
            "unit": unit,
            "currency": currency,
            "quantity": str(quantity),
            "pricePerUnit": str(price),
            "matchedRule": f"{_pricing_text(rule, 'provider', default=record.provider or '*')}:{unit}",
        },
    )


def _estimate_oss_processing_cost(record: ProcessingCostEventRecord) -> ProcessingCostEstimate:
    config = _processing_global_rates("oss")
    if not config:
        return ProcessingCostEstimate(None, None, "not_available")
    currency = _pricing_text(config, "currency", default=_token_cost_currency())
    metadata = record.metadata if isinstance(record.metadata, dict) else {}
    bytes_value = _oss_bytes_value(record, metadata)
    gb_value = bytes_value / Decimal(1024 * 1024 * 1024) if bytes_value > 0 else Decimal("0")
    put_count = _metadata_decimal(metadata, "putCount", "put_count", "puts")
    get_count = _metadata_decimal(metadata, "getCount", "get_count", "gets")
    if put_count <= 0 and _pricing_key(record.event_type) in {"oss_upload", "oss_put"}:
        put_count = Decimal("1")
    if get_count <= 0 and _pricing_key(record.event_type) in {"oss_upload", "oss_download", "oss_get"}:
        get_count = Decimal("1")
    retention_days = _metadata_decimal(metadata, "retentionDays", "retention_days")
    if retention_days <= 0:
        retention_days = _pricing_decimal(config, "retentionDays", "retention_days", "defaultRetentionDays")

    put_rate = _pricing_decimal(config, "putPer10000", "put_per_10000", "putRequestsPer10000")
    get_rate = _pricing_decimal(config, "getPer10000", "get_per_10000", "getRequestsPer10000")
    traffic_rate = _pricing_decimal(config, "trafficGb", "trafficPerGb", "downloadGb", "downloadPerGb")
    storage_rate = _pricing_decimal(config, "storageGbMonth", "storagePerGbMonth", "storage_gb_month")

    components: dict[str, Decimal] = {}
    if put_count > 0 and put_rate > 0:
        components["put"] = put_count / Decimal(10000) * put_rate
    if get_count > 0 and get_rate > 0:
        components["get"] = get_count / Decimal(10000) * get_rate
    if gb_value > 0 and traffic_rate > 0:
        components["traffic"] = gb_value * traffic_rate
    if gb_value > 0 and retention_days > 0 and storage_rate > 0:
        components["storage"] = gb_value * (retention_days / Decimal(30)) * storage_rate
    if not components:
        return ProcessingCostEstimate(None, currency, "missing_processing_rate")

    cost = sum(components.values(), Decimal("0")).quantize(Decimal("0.000001"))
    return ProcessingCostEstimate(
        cost,
        currency,
        "estimated_oss_rate",
        {
            "source": "KB_PROCESSING_COST_RATES_JSON",
            "type": "oss",
            "currency": currency,
            "bytes": str(bytes_value),
            "gb": str(gb_value.quantize(Decimal("0.000001"))),
            "putCount": str(put_count),
            "getCount": str(get_count),
            "retentionDays": str(retention_days),
            "rates": {
                "putPer10000": str(put_rate),
                "getPer10000": str(get_rate),
                "trafficGb": str(traffic_rate),
                "storageGbMonth": str(storage_rate),
            },
            "components": {key: str(value.quantize(Decimal("0.000001"))) for key, value in components.items()},
        },
    )


def _processing_rule_has_metadata_conditions(rule: dict[str, Any]) -> bool:
    for key in ("metadata", "metadataEquals", "metadata_equals", "matchMetadata", "match_metadata"):
        value = rule.get(key)
        if isinstance(value, dict) and value:
            return True
    for key in (
        "billingTier",
        "billing_tier",
        "parseBillingTier",
        "parse_billing_tier",
        "parseMode",
        "parse_mode",
    ):
        if rule.get(key) is not None and str(rule.get(key)).strip():
            return True
    return False


def _processing_rule_metadata_matches(rule: dict[str, Any], record: ProcessingCostEventRecord) -> bool:
    metadata = record.metadata if isinstance(record.metadata, dict) else {}
    conditions: dict[str, Any] = {}
    for key in ("metadata", "metadataEquals", "metadata_equals", "matchMetadata", "match_metadata"):
        value = rule.get(key)
        if isinstance(value, dict):
            conditions.update(value)
    for key in (
        "billingTier",
        "billing_tier",
        "parseBillingTier",
        "parse_billing_tier",
        "parseMode",
        "parse_mode",
    ):
        value = rule.get(key)
        if value is not None and str(value).strip():
            conditions[key] = value
    for key, expected in conditions.items():
        if expected is None or str(expected).strip() == "":
            continue
        actual = _metadata_lookup(metadata, key)
        if actual is None or _pricing_key(actual) != _pricing_key(expected):
            return False
    return True


def _metadata_lookup(metadata: dict[str, Any], key: str) -> Any:
    candidates = [key]
    if "_" in key:
        parts = key.split("_")
        candidates.append(parts[0] + "".join(part.capitalize() for part in parts[1:]))
    else:
        snake = []
        for char in key:
            if char.isupper():
                snake.append("_")
                snake.append(char.lower())
            else:
                snake.append(char)
        candidates.append("".join(snake).lstrip("_"))
    for candidate in dict.fromkeys(candidates):
        if candidate in metadata:
            return metadata.get(candidate)
    return None


def _parse_cost_unit_price(rule: dict[str, Any], unit: str) -> Decimal:
    if unit in {"page", "pages"}:
        return _pricing_decimal(rule, "pricePerPage", "price_per_page", "pagePrice", "pricePerUnit", "price_per_unit")
    if unit in {"task", "tasks", "request", "requests"}:
        return _pricing_decimal(rule, "pricePerTask", "price_per_task", "taskPrice", "pricePerUnit", "price_per_unit")
    if unit in {"shard", "shards"}:
        return _pricing_decimal(rule, "pricePerShard", "price_per_shard", "shardPrice", "pricePerUnit", "price_per_unit")
    if unit in {"content_block", "content_blocks", "block", "blocks"}:
        return _pricing_decimal(rule, "pricePerContentBlock", "price_per_content_block", "pricePerBlock", "pricePerUnit", "price_per_unit")
    if unit in {"mb", "megabyte", "megabytes"}:
        return _pricing_decimal(rule, "pricePerMb", "price_per_mb", "pricePerUnit", "price_per_unit")
    if unit in {"gb", "gigabyte", "gigabytes"}:
        return _pricing_decimal(rule, "pricePerGb", "price_per_gb", "pricePerUnit", "price_per_unit")
    return _pricing_decimal(rule, "pricePerUnit", "price_per_unit")


def _parse_cost_quantity(record: ProcessingCostEventRecord, unit: str) -> Decimal:
    metadata = record.metadata if isinstance(record.metadata, dict) else {}
    if unit in {"page", "pages"}:
        quantity = _metadata_decimal(metadata, "pageCount", "page_count", "parseServiceInputPages", "inputPages", "totalPages")
        if quantity <= 0 and _pricing_key(record.metric_unit) in {"page", "pages"}:
            quantity = _decimal_value(record.metric_value)
        return quantity
    if unit in {"task", "tasks", "request", "requests"}:
        return Decimal("1")
    if unit in {"shard", "shards"}:
        quantity = _metadata_decimal(metadata, "shardCount", "parseShardCount", "submittedShards")
        return quantity if quantity > 0 else Decimal("1")
    if unit in {"content_block", "content_blocks", "block", "blocks"}:
        quantity = _metadata_decimal(metadata, "outputBlocks", "contentBlocks")
        if quantity <= 0 and _pricing_key(record.metric_unit) in {"content_blocks", "content_block", "blocks", "block"}:
            quantity = _decimal_value(record.metric_value)
        return quantity
    if unit in {"mb", "megabyte", "megabytes"}:
        bytes_value = _metadata_decimal(metadata, "fileSizeBytes", "sourceFileSizeBytes", "bytes")
        if bytes_value <= 0 and _pricing_key(record.metric_unit) == "bytes":
            bytes_value = _decimal_value(record.metric_value)
        if bytes_value > 0:
            return bytes_value / Decimal(1024 * 1024)
        return _metadata_decimal(metadata, "fileSizeMb", "file_size_mb")
    if unit in {"gb", "gigabyte", "gigabytes"}:
        bytes_value = _metadata_decimal(metadata, "fileSizeBytes", "sourceFileSizeBytes", "bytes")
        if bytes_value <= 0 and _pricing_key(record.metric_unit) == "bytes":
            bytes_value = _decimal_value(record.metric_value)
        if bytes_value > 0:
            return bytes_value / Decimal(1024 * 1024 * 1024)
        return _metadata_decimal(metadata, "fileSizeGb", "file_size_gb")
    return _decimal_value(record.metric_value)


def _oss_bytes_value(record: ProcessingCostEventRecord, metadata: dict[str, Any]) -> Decimal:
    bytes_value = _metadata_decimal(metadata, "bytes", "fileSizeBytes", "sourceFileSizeBytes", "uploadBytes", "downloadBytes", "storageBytes")
    if bytes_value <= 0 and _pricing_key(record.metric_unit) == "bytes":
        bytes_value = _decimal_value(record.metric_value)
    return bytes_value


def _metadata_decimal(metadata: dict[str, Any], *keys: str) -> Decimal:
    for key in keys:
        if key in metadata:
            value = _decimal_value(metadata.get(key))
            if value > 0:
                return value
    return Decimal("0")


def _decimal_value(value: Any) -> Decimal:
    try:
        decimal_value = Decimal(str(value or "0"))
    except (InvalidOperation, ValueError, TypeError):
        return Decimal("0")
    return decimal_value if decimal_value > 0 else Decimal("0")


def _pricing_match_score(
    *,
    rule_provider: str,
    rule_model: str,
    rule_event_type: str,
    provider: str,
    model_name: str,
    event_type: str,
) -> int | None:
    score = 0
    if rule_provider and rule_provider != "*":
        if rule_provider != provider:
            return None
        score += 8
    if rule_model and rule_model != "*":
        if rule_model != model_name:
            return None
        score += 4
    if rule_event_type and rule_event_type != "*":
        if rule_event_type != event_type:
            return None
        score += 2
    return score


def _resolve_token_pricing(record: LlmCallLogRecord, *, event_type: str | None = None) -> TokenPricing:
    resolved_event_type = event_type or _llm_event_type(record)
    provider = _pricing_key(record.provider)
    model_name = _pricing_key(record.model_name)
    event_key = _pricing_key(resolved_event_type)
    best: tuple[int, int, dict[str, Any], tuple[Decimal, Decimal, Decimal]] | None = None
    for index, rule in enumerate(_token_model_rate_rules()):
        prompt_rate, completion_rate, total_rate = _token_rate_tuple_from_rule(rule)
        if not any(rate > 0 for rate in (prompt_rate, completion_rate, total_rate)):
            continue
        rule_provider = _pricing_key(_pricing_text(rule, "provider", default="*") or "*")
        rule_model = _pricing_key(_pricing_text(rule, "model", "modelName", "model_name", default="*") or "*")
        rule_event_type = _pricing_key(_pricing_text(rule, "eventType", "event_type", default="*") or "*")
        score = _pricing_match_score(
            rule_provider=rule_provider,
            rule_model=rule_model,
            rule_event_type=rule_event_type,
            provider=provider,
            model_name=model_name,
            event_type=event_key,
        )
        if score is None:
            continue
        if best is None or score > best[0] or (score == best[0] and index < best[1]):
            best = (score, index, rule, (prompt_rate, completion_rate, total_rate))

    if best is not None:
        rule = best[2]
        prompt_rate, completion_rate, total_rate = best[3]
        rule_provider = _pricing_text(rule, "provider", default=record.provider or "*")
        rule_model = _pricing_text(rule, "model", "modelName", "model_name", default=record.model_name or "*")
        rule_event_type = _pricing_text(rule, "eventType", "event_type", default=resolved_event_type or "*")
        return TokenPricing(
            source="configured_model_rate",
            currency=_pricing_text(rule, "currency", default=_token_cost_currency()),
            prompt_per_1k=prompt_rate,
            completion_per_1k=completion_rate,
            total_per_1k=total_rate,
            provider=rule_provider,
            model_name=rule_model,
            event_type=rule_event_type,
            matched_rule=f"{rule_provider}:{rule_model}:{rule_event_type}",
        )

    prompt_rate, completion_rate, total_rate = _token_cost_rates()
    if any(rate > 0 for rate in (prompt_rate, completion_rate, total_rate)):
        return TokenPricing(
            source="configured_rate",
            currency=_token_cost_currency(),
            prompt_per_1k=prompt_rate,
            completion_per_1k=completion_rate,
            total_per_1k=total_rate,
            provider="*",
            model_name="*",
            event_type="*",
            matched_rule="global",
        )
    return TokenPricing(
        source="missing_model_rate" if _token_model_rate_rules() else "not_available",
        currency=_token_cost_currency(),
        provider=record.provider or "",
        model_name=record.model_name or "",
        event_type=resolved_event_type or "",
    )


def _token_pricing_metadata(pricing: TokenPricing) -> dict[str, Any]:
    return {
        "source": pricing.source,
        "provider": pricing.provider,
        "model": pricing.model_name,
        "eventType": pricing.event_type,
        "currency": pricing.currency,
        "promptPer1k": str(pricing.prompt_per_1k),
        "completionPer1k": str(pricing.completion_per_1k),
        "totalPer1k": str(pricing.total_per_1k),
        "matchedRule": pricing.matched_rule,
    }


def _estimate_token_cost(
    *,
    prompt_tokens: int,
    completion_tokens: int,
    total_tokens: int,
    pricing: TokenPricing | None = None,
) -> Decimal | None:
    resolved_pricing = pricing
    if resolved_pricing is None:
        prompt_rate, completion_rate, total_rate = _token_cost_rates()
        resolved_pricing = TokenPricing(
            source=_token_cost_source(),
            currency=_token_cost_currency(),
            prompt_per_1k=prompt_rate,
            completion_per_1k=completion_rate,
            total_per_1k=total_rate,
        )
    if not resolved_pricing.configured:
        return None
    cost = (
        Decimal(max(0, prompt_tokens)) / Decimal(1000) * resolved_pricing.prompt_per_1k
        + Decimal(max(0, completion_tokens)) / Decimal(1000) * resolved_pricing.completion_per_1k
        + Decimal(max(0, total_tokens)) / Decimal(1000) * resolved_pricing.total_per_1k
    )
    return cost.quantize(Decimal("0.000001"))


def _decimal_float(value: Any) -> float:
    try:
        return float(value or 0)
    except (TypeError, ValueError):
        return 0.0


SENSITIVE_AUDIT_METADATA_KEYS = {
    "plainkey",
    "plain_key",
    "key",
    "keyhash",
    "key_hash",
    "apikey",
    "api_key",
    "secret",
    "password",
    "token",
    "credential",
    "authorization",
    "query",
    "answer",
    "prompt",
    "content",
}


def _sanitize_audit_metadata(metadata: dict[str, Any]) -> dict[str, Any]:
    safe: dict[str, Any] = {}
    for key, value in metadata.items():
        normalized = str(key).replace("-", "_").lower()
        if normalized in SENSITIVE_AUDIT_METADATA_KEYS or any(token in normalized for token in ("secret", "password", "token")):
            safe[str(key)] = "***"
            continue
        if isinstance(value, dict):
            safe[str(key)] = _sanitize_audit_metadata(value)
        elif isinstance(value, list):
            safe[str(key)] = [
                _sanitize_audit_metadata(item) if isinstance(item, dict) else _safe_audit_scalar(item)
                for item in value[:50]
            ]
        else:
            safe[str(key)] = _safe_audit_scalar(value)
    return safe


def _safe_audit_scalar(value: Any) -> Any:
    if value is None or isinstance(value, (bool, int, float)):
        return value
    return _summary(str(value), 200)


def _summary(value: str, max_len: int = 160) -> str:
    text = " ".join((value or "").split())
    if len(text) <= max_len:
        return text
    return text[: max_len - 1] + "..."


def _iso(value: Any) -> str:
    if isinstance(value, datetime):
        return value.isoformat()
    return str(value or "")


def _log_row_to_payload(row: tuple[Any, ...]) -> dict[str, Any]:
    return {
        "requestId": row[0],
        "pipelineDomain": row[1],
        "pipelineStage": row[2],
        "tenantId": row[3],
        "actorId": row[4],
        "kbId": row[5],
        "apiKeyId": row[6],
        "queryHash": row[7],
        "querySummary": row[8] or "",
        "answerSummary": row[9] or "",
        "cannotAnswer": bool(row[10]),
        "relevanceScore": row[11],
        "faithfulnessScore": row[12],
        "promptTokens": int(row[13] or 0),
        "completionTokens": int(row[14] or 0),
        "totalTokens": int(row[15] or 0),
        "latencyMs": int(row[16] or 0),
        "status": row[17],
        "errorCode": row[18],
        "createdAt": _iso(row[19]),
    }


def _audit_row_to_payload(row: tuple[Any, ...]) -> dict[str, Any]:
    metadata = row[14] or {}
    if isinstance(metadata, str):
        try:
            metadata = json.loads(metadata)
        except json.JSONDecodeError:
            metadata = {}
    return {
        "id": int(row[0]),
        "requestId": row[1],
        "tenantId": row[2],
        "actorId": row[3],
        "actorName": row[4],
        "actorSource": row[5],
        "action": row[6],
        "resourceType": row[7],
        "resourceId": row[8],
        "kbId": row[9],
        "apiKeyId": row[10],
        "outcome": row[11],
        "riskLevel": row[12],
        "summary": row[13] or "",
        "metadata": metadata if isinstance(metadata, dict) else {},
        "createdAt": _iso(row[15]),
    }


def _aggregate_row(row: tuple[Any, ...], label_key: str | None = None) -> dict[str, Any]:
    offset = 1 if label_key else 0
    payload = {
        "requestCount": int(row[0 + offset] or 0),
        "promptTokens": int(row[1 + offset] or 0),
        "completionTokens": int(row[2 + offset] or 0),
        "totalTokens": int(row[3 + offset] or 0),
        "avgLatencyMs": round(float(row[4 + offset] or 0), 2),
    }
    if label_key:
        payload = {label_key: row[0], **payload}
    return payload


def _processing_cost_overall_row(row: tuple[Any, ...] | None) -> dict[str, Any]:
    if not row:
        return {
            "eventCount": 0,
            "promptTokens": 0,
            "completionTokens": 0,
            "totalTokens": 0,
            "durationMs": 0,
            "errorCount": 0,
            "estimatedCost": 0.0,
        }
    return {
        "eventCount": int(row[0] or 0),
        "promptTokens": int(row[1] or 0),
        "completionTokens": int(row[2] or 0),
        "totalTokens": int(row[3] or 0),
        "durationMs": int(row[4] or 0),
        "errorCount": int(row[5] or 0),
        "estimatedCost": round(_decimal_float(row[6]), 6),
    }


def _processing_cost_breakdown_row(row: tuple[Any, ...] | None) -> dict[str, Any]:
    if not row:
        return {
            "currency": "",
            "totalEstimatedCost": 0.0,
            "modelEstimatedCost": 0.0,
            "parseEstimatedCost": 0.0,
            "ossEstimatedCost": 0.0,
            "otherEstimatedCost": 0.0,
            "costAvailable": False,
            "allCostAvailable": True,
            "costAvailableCount": 0,
            "costUnavailableCount": 0,
            "model": _cost_component_payload(),
            "parse": _cost_component_payload(),
            "oss": _cost_component_payload(),
            "other": _cost_component_payload(),
        }
    cost_available_count = int(row[1] or 0)
    cost_unavailable_count = int(row[2] or 0)
    model = _cost_component_payload(row[4], row[5], row[6], row[7])
    parse = _cost_component_payload(row[8], row[9], row[10], row[11])
    oss = _cost_component_payload(row[12], row[13], row[14], row[15])
    other = _cost_component_payload(row[16], row[17], row[18], row[19])
    return {
        "currency": row[3] or "",
        "totalEstimatedCost": round(_decimal_float(row[0]), 6),
        "modelEstimatedCost": model["estimatedCost"],
        "parseEstimatedCost": parse["estimatedCost"],
        "ossEstimatedCost": oss["estimatedCost"],
        "otherEstimatedCost": other["estimatedCost"],
        "costAvailable": cost_available_count > 0,
        "allCostAvailable": cost_unavailable_count == 0,
        "costAvailableCount": cost_available_count,
        "costUnavailableCount": cost_unavailable_count,
        "model": model,
        "parse": parse,
        "oss": oss,
        "other": other,
    }


def _cost_component_payload(
    event_count: Any = 0,
    estimated_cost: Any = 0,
    cost_available_count: Any = 0,
    cost_unavailable_count: Any = 0,
) -> dict[str, Any]:
    available_count = int(cost_available_count or 0)
    unavailable_count = int(cost_unavailable_count or 0)
    return {
        "eventCount": int(event_count or 0),
        "estimatedCost": round(_decimal_float(estimated_cost), 6),
        "costAvailable": available_count > 0,
        "allCostAvailable": unavailable_count == 0,
        "costAvailableCount": available_count,
        "costUnavailableCount": unavailable_count,
    }


def _project_cost_overall_row(row: tuple[Any, ...] | None) -> dict[str, Any]:
    if not row:
        return {
            "eventCount": 0,
            "estimatedCost": 0.0,
            "costAvailableCount": 0,
            "costUnavailableCount": 0,
            "costAvailable": False,
            "currency": "",
            "parseEventCount": 0,
            "parseEstimatedCost": 0.0,
            "ossEventCount": 0,
            "ossEstimatedCost": 0.0,
            "parsePages": 0.0,
            "ossBytes": 0.0,
            "firstOccurredAt": "",
            "lastOccurredAt": "",
        }
    cost_available_count = int(row[2] or 0)
    return {
        "eventCount": int(row[0] or 0),
        "estimatedCost": round(_decimal_float(row[1]), 6),
        "costAvailableCount": cost_available_count,
        "costUnavailableCount": int(row[3] or 0),
        "costAvailable": cost_available_count > 0,
        "currency": row[4] or "",
        "parseEventCount": int(row[5] or 0),
        "parseEstimatedCost": round(_decimal_float(row[6]), 6),
        "ossEventCount": int(row[7] or 0),
        "ossEstimatedCost": round(_decimal_float(row[8]), 6),
        "parsePages": _decimal_float(row[9]),
        "ossBytes": _decimal_float(row[10]),
        "firstOccurredAt": _iso(row[11]),
        "lastOccurredAt": _iso(row[12]),
    }


